                <Switch
                  value={foodForm.isAvailable}
                  onValueChange={(v) =>
                    setFoodForm((f) => ({ ...f, isAvailable: v }))
                  }
                  trackColor={{ true: "#F26A4A", false: "#ECE6DA" }}
