/* ============================================================
 * ⭐ NEW: Churn rate за выбранный период.
 *
 * Что такое churn: % клиентов, которые были активны в "окне
 * наблюдения", но НЕ активны в "окне измерения".
 *
 * Пример: churn(30) = сколько % клиентов, делавших заказы в
 * предыдущие 30 дней, НЕ сделали ни одного заказа за последние 30.
 *
 * Возвращает:
 *   - period: 30 (как запрашивали)
 *   - activeAtStart: клиенты с заказами в [start-period, start]
 *   - churned: из них не заказывали в [start, end]
 *   - retained: из них заказывали в [start, end]
 *   - churnRatePct: 100 * churned / activeAtStart
 *   - avgOrdersPerRetained: средний кол-во заказов у retained
 * ============================================================ */
export const churnRate = async (_p, { period: periodArg }, ctx) => {
  requireRole(["SUPER_ADMIN", "FINANCE", "ANALYST"])(ctx);

  const period = Math.max(7, Math.min(180, periodArg || 30));

  const now = new Date();
  // Окно наблюдения: [start-period, start]
  const observeEnd = new Date(now.getTime() - period * 24 * 60 * 60 * 1000);
  // Окно измерения: [start, end]
  const measureStart = observeEnd;
  const measureEnd = now;

  // Шаг 1: клиенты, активные в окне наблюдения (хотя бы 1 заказ)
  const observeAgg = await Order.aggregate([
    {
      $match: {
        orderStatus: "DELIVERED",
        createdAt: { $gte: observeEnd, $lt: measureStart },
      },
    },
    {
      $group: {
        _id: "$userId",
        ordersInPeriod: { $sum: 1 },
      },
    },
    {
      $project: {
        _id: 0,
        userId: { $toString: "$_id" },
        ordersInPeriod: 1,
      },
    },
  ]);

  const activeAtStart = observeAgg.length;
  if (activeAtStart === 0) {
    return {
      period,
      activeAtStart: 0,
      churned: 0,
      retained: 0,
      churnRatePct: 0,
      retentionRatePct: 0,
      avgOrdersPerRetained: 0,
    };
  }

  // Шаг 2: из них — кто заказывал в окне измерения
  const retainedUserIds = new Set();
  const orderCountsInMeasure = new Map();

  const measureAgg = await Order.aggregate([
    {
      $match: {
        orderStatus: "DELIVERED",
        createdAt: { $gte: measureStart, $lte: measureEnd },
      },
    },
    {
      $group: {
        _id: "$userId",
        ordersInMeasure: { $sum: 1 },
      },
    },
  ]);

  for (const row of measureAgg) {
    const uid = String(row._id);
    retainedUserIds.add(uid);
    orderCountsInMeasure.set(uid, row.ordersInMeasure);
  }

  // Шаг 3: пересечение
  const activeIds = new Set(observeAgg.map((r) => r.userId));
  let retained = 0;
  let totalOrdersForRetained = 0;
  for (const uid of activeIds) {
    if (retainedUserIds.has(uid)) {
      retained++;
      totalOrdersForRetained += orderCountsInMeasure.get(uid) || 0;
    }
  }
  const churned = activeAtStart - retained;
  const churnRatePct = +((churned / activeAtStart) * 100).toFixed(1);
  const retentionRatePct = +((retained / activeAtStart) * 100).toFixed(1);
  const avgOrdersPerRetained =
    retained > 0 ? +(totalOrdersForRetained / retained).toFixed(2) : 0;

  return {
    period,
    activeAtStart,
    churned,
    retained,
    churnRatePct,
    retentionRatePct,
    avgOrdersPerRetained,
  };
};

/* ============================================================
 * ⭐ NEW: Прогноз спроса (demand forecast) на N дней.
 *
 * Использует простую линейную регрессию по дневной выручке за
 * последние 60 дней. Возвращает:
 *   - history: [{ date, revenue, orders }] за каждый день
 *   - forecast: [{ date, predictedRevenue, predictedOrders, isForecast: true }]
 *   - totals: { avgDailyRevenue, totalForecastRevenue, trendPct }
 *
 * trendPct: % изменения средней выручки за последнюю треть
 * относительно первой трети. Положительный = рост.
 * ============================================================ */
export const demandForecast = async (_p, { days: daysArg }, ctx) => {
  requireRole(["SUPER_ADMIN", "FINANCE", "ANALYST"])(ctx);

  const days = Math.max(1, Math.min(30, daysArg || 7));
  const historyDays = 60;

  const since = new Date(Date.now() - historyDays * 24 * 60 * 60 * 1000);
  since.setHours(0, 0, 0, 0);

  // Шаг 1: дневная статистика за последние 60 дней
  const dailyStats = await Order.aggregate([
    {
      $match: {
        orderStatus: "DELIVERED",
        createdAt: { $gte: since },
      },
    },
    {
      $group: {
        _id: {
          $dateToString: { format: "%Y-%m-%d", date: "$createdAt" },
        },
        revenue: { $sum: "$amounts.total" },
        orders: { $sum: 1 },
      },
    },
    { $sort: { _id: 1 } },
  ]);

  // Шаг 2: восполняем пропуски (дни без заказов) нулями
  const historyMap = new Map();
  for (let i = 0; i < historyDays; i++) {
    const d = new Date(since);
    d.setDate(d.getDate() + i);
    const k = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`;
    if (!historyMap.has(k))
      historyMap.set(k, { date: k, revenue: 0, orders: 0 });
  }
  for (const row of dailyStats) {
    const existing = historyMap.get(row._id);
    if (existing) {
      existing.revenue = +row.revenue.toFixed(2);
      existing.orders = row.orders;
    } else {
      historyMap.set(row._id, {
        date: row._id,
        revenue: +row.revenue.toFixed(2),
        orders: row.orders,
      });
    }
  }
  const history = Array.from(historyMap.values());

  // Шаг 3: простая линейная регрессия (y = a*x + b) по дням
  // x = 0..N-1, y = revenue. По closed-form формуле.
  // Если данных < 3, прогноз ненадёжен — возвращаем простую среднюю.
  const n = history.length;
  let slope = 0;
  let intercept = 0;
  let avgRevenue = 0;
  let avgOrders = 0;

  if (n >= 3) {
    let sumX = 0;
    let sumY = 0;
    let sumXY = 0;
    let sumXX = 0;
    for (let i = 0; i < n; i++) {
      sumX += i;
      sumY += history[i].revenue;
      sumXY += i * history[i].revenue;
      sumXX += i * i;
    }
    const meanX = sumX / n;
    const meanY = sumY / n;
    const denom = sumXX - n * meanX * meanX;
    if (denom !== 0) {
      slope = (sumXY - n * meanX * meanY) / denom;
      intercept = meanY - slope * meanX;
    } else {
      slope = 0;
      intercept = meanY;
    }
    // Защита от отрицательных прогнозов
    if (slope + intercept < 0) {
      slope = 0;
      intercept = meanY;
    }
  }

  for (const d of history) {
    avgRevenue += d.revenue;
    avgOrders += d.orders;
  }
  avgRevenue = +(avgRevenue / n).toFixed(2);
  avgOrders = +(avgOrders / n).toFixed(2);

  // Шаг 4: тренд (% изменения последней трети vs первой)
  const thirdSize = Math.max(1, Math.floor(n / 3));
  const firstThird = history.slice(0, thirdSize);
  const lastThird = history.slice(-thirdSize);
  const firstAvg =
    firstThird.reduce((s, d) => s + d.revenue, 0) / firstThird.length || 0;
  const lastAvg =
    lastThird.reduce((s, d) => s + d.revenue, 0) / lastThird.length || 0;
  const trendPct =
    firstAvg > 0 ? +(((lastAvg - firstAvg) / firstAvg) * 100).toFixed(1) : 0;

  // Шаг 5: прогноз на следующие N дней
  const forecast = [];
  let totalForecastRevenue = 0;
  for (let i = 0; i < days; i++) {
    const d = new Date();
    d.setDate(d.getDate() + i + 1);
    d.setHours(0, 0, 0, 0);
    const k = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, "0")}-${String(d.getDate()).padStart(2, "0")}`;
    const x = n + i;
    const predictedRevenue =
      n >= 3 ? +Math.max(0, slope * x + intercept).toFixed(2) : avgRevenue;
    // Заказы пропорционально выручке / средний чек
    const predictedOrders =
      avgOrderValue > 0 && predictedRevenue > 0
        ? Math.round(predictedRevenue / avgOrderValue)
        : Math.round(avgOrders);
    totalForecastRevenue += predictedRevenue;
    forecast.push({
      date: k,
      predictedRevenue,
      predictedOrders,
      isForecast: true,
    });
  }

  return {
    history,
    forecast,
    totals: {
      avgDailyRevenue: avgRevenue,
      avgDailyOrders: avgOrders,
      totalForecastRevenue: +totalForecastRevenue.toFixed(2),
      trendPct,
    },
  };
};
