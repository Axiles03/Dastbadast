                <Text className="text-text-inverse font-extrabold text-base">
                  {busy ? "..." : "Сохранить"}
                </Text>
              </TouchableOpacity>
            </View>
          </ScrollView>
        </KeyboardAvoidingView>
      </Modal>
    </View>
  );
}
