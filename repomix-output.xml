export async function notifyRidersNewOrder({
  riderIds,
  orderId,
  orderCode,
  restaurantName,
  total,
  etaMin,
}) {
  await Promise.allSettled(
    (riderIds || []).map((riderId) =>
      notify({
        to: "rider",
        toId: riderId,
        event: "NEW_ORDER_TO_RIDER",
        vars: {
          orderId,
          orderCode,
          restaurantName,
          total,
          etaMin: etaMin ?? "?",
        },
