  "https://images.unsplash.com/photo-1466978913421-dad2ebd01d17?w=900&q=80",
];

function hash(s: string) {
  let h = 0;
  for (let i = 0; i < s.length; i++) {
    h = (h << 5) - h + s.charCodeAt(i);
    h |= 0;
  }
  return Math.abs(h);
}

export function RestaurantCard({
  restaurant,
  currencySymbol,
  variant = "grid",
}: {
