  useSubscription,
  useApolloClient,
} from "@apollo/client/react";
import {
  MY_ORDERS,
  AVAILABLE_ORDERS,
  CLAIM_ORDER,
  UPDATE_STATUS,
  TOGGLE,
  SUB_ASSIGNED,
  SUB_AVAILABLE,
  SUB_RIDER_ORDER_COMPLETED,
  SUB_RIDER_LOCATION,
  COURIER_SEARCH_NOTIFY,
} from "../../lib/api/queries";
