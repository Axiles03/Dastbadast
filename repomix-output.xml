                  {food.averageRating?.toFixed(1) ?? "—"}
                </span>
                <span>·</span>
                <span>
                  {food.reviewCount ?? reviews.length}{" "}
                  {food.reviewCount === 1 ? "отзыв" : "отзывов"}
