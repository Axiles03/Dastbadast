import { View, Text } from "react-native";

const PALETTE: Record<
  string,
  { bg: string; text: string; emoji: string; label: string }
> = {
  PENDING: {
    bg: "bg-warning-soft",
    text: "text-warning-dark",
    emoji: "⏱",
    label: "Новый",
  },
  ACCEPTED: {
    bg: "bg-purple-soft",
