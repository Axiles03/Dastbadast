    reviews: async (parent) => {
      const { FoodReview } = await import("../models/FoodReview.js");
      return FoodReview.find({ foodId: parent._id })
        .sort({ createdAt: -1 })
        .limit(10);
    },
  },
  FoodReview: {
    id: mongoId,
    createdAt: (p) => p.createdAt?.toISOString?.() ?? String(p.createdAt ?? ""),
  },
  Rider: { id: mongoId },
  Owner: {
