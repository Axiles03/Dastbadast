    emoji: "👨‍🍳",
    label: "Готовится",
  },
  ASSIGNED: {
    bg: "bg-accent-soft",
    text: "text-accent-dark",
    emoji: "🛵",
    label: "Курьер едет",
  },
  PICKED: {
    bg: "bg-info-soft",
    text: "text-info-dark",
    emoji: "🚴",
    label: "В пути",
  },
  AWAITING_CONFIRMATION: {
    bg: "bg-warning-soft",
