        {/* ───── Кнопки Сохранить / Отмена ───── */}
        {editing && (
          <div className="flex gap-2 mt-5 pt-5 border-t border-soft-border">
            <button
              type="button"
              onClick={() => {
                setEditing(false);
                setPhoneError(null);
