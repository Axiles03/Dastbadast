{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"delivery_price_service","label":"delivery-price.service.js","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/services/delivery-price.service.js","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/services/delivery-price.service.js","source_location":"L1"}]},{"id":"delivery_price_service_getpricingconfig","label":"getPricingConfig()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/services/delivery-price.service.js","source_location":"L36-L61","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/services/delivery-price.service.js","source_location":"L36"}],"snippet":"export async function getPricingConfig() {\n  let cfg = null;\n  try {\n    cfg = await Configuration.findById(\"singleton\")\n      .select(\"deliveryBaseKm deliveryBasePrice deliveryPerKmPrice\")\n      .lean();\n  } catch (e) {\n    debugWarn(SERVICE, \"config read failed, using defaults\", {\n      message: e?.message,\n    });\n  }\n\n  return {\n    basePrice: Number.isFinite(cfg?.deliveryBasePrice)\n      ? cfg.deliveryBasePrice\n      : DELIVERY_PRICING.basePrice,\n    baseKm: Number.isFinite(cfg?.deliveryBaseKm)\n      ? cfg.deliveryBaseKm\n      : DELIVERY_PRICING.baseKm,\n    perKmPrice: Number.isFinite(cfg?.deliveryPerKmPrice)\n      ? cfg.deliveryPerKmPrice\n      : DELIVERY_PRICING.perKmPrice,\n    currency: DELIVERY_PRICING.currency,\n    currencySymbol: DELIVERY_PRICING.currencySymbol,\n  };"},{"id":"delivery_price_service_validatecoordinates","label":"validateCoordinates()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/services/delivery-price.service.js","source_location":"L67-L92","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/services/delivery-price.service.js","source_location":"L67"}],"snippet":"function validateCoordinates(coords, what) {\n  if (!Array.isArray(coords) || coords.length < 2) {\n    throw new GraphQLError(`${what} has no coordinates`, {\n      extensions: { code: \"BAD_USER_INPUT\" },\n    });\n  }\n  const [lng, lat] = coords;\n  if (typeof lng !== \"number\" || typeof lat !== \"number\") {\n    throw new GraphQLError(`${what} coordinates are not numbers`, {\n      extensions: { code: \"BAD_USER_INPUT\" },\n    });\n  }\n  if (Math.abs(lng) > 180 || Math.abs(lat) > 90) {\n    throw new GraphQLError(`${what} coordinates out of range`, {\n      extensions: { code: \"BAD_USER_INPUT\" },\n    });\n  }\n  if (lng === 0 && lat === 0) {\n    // \"нулевые\" координаты = не настроен ресторан / не выбран адрес\n    throw new GraphQLError(\n      `${what} has no real GPS coordinates (0,0). Select an address on the map.`,\n      { extensions: { code: \"BAD_USER_INPUT\" } },\n    );\n  }\n  return [lng, lat];"},{"id":"delivery_price_service_assertpointinactivezone","label":"assertPointInActiveZone()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/services/delivery-price.service.js","source_location":"L98-L118","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/services/delivery-price.service.js","source_location":"L98"}],"snippet":"async function assertPointInActiveZone(lng, lat) {\n  const zone = await Zone.findOne({ isActive: true }).lean();\n  if (!zone) {\n    throw new GraphQLError(\n      \"Delivery zone is not configured. Run seed on API first.\",\n      { extensions: { code: \"ZONE_NOT_CONFIGURED\" } },\n    );\n  }\n  const polygon = zone.location?.coordinates?.[0];\n  if (!Array.isArray(polygon) || polygon.length < 3) {\n    throw new GraphQLError(\"Active zone has no valid polygon\", {\n      extensions: { code: \"ZONE_INVALID\" },\n    });\n  }\n  if (!pointInPolygon([lng, lat], polygon)) {\n    throw new GraphQLError(\n      \"Address is outside the delivery zone. Pick a point on the map inside the highlighted area.\",\n      { extensions: { code: \"OUT_OF_ZONE\" } },\n    );\n  }\n}"},{"id":"delivery_price_service_calculateserverdeliveryprice","label":"calculateServerDeliveryPrice()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/services/delivery-price.service.js","source_location":"L137-L233","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/services/delivery-price.service.js","source_location":"L137"}],"snippet":"export async function calculateServerDeliveryPrice({\n  restaurantId,\n  addressId,\n  userId = null,\n}) {\n  // 1. Загружаем сущности\n  const [Restaurant, User] = await Promise.all([\n    import(\"../models/Restaurant.js\").then((m) => m.Restaurant),\n    import(\"../models/User.js\").then((m) => m.User),\n  ]);\n\n  const [restaurant, user] = await Promise.all([\n    Restaurant.findById(restaurantId).lean(),\n    User.findById(userId).lean(),\n  ]);\n\n  if (!restaurant) {\n    throw new GraphQLError(`Restaurant not found: ${restaurantId}`, {\n      extensions: { code: \"RESTAURANT_NOT_FOUND\" },\n    });\n  }\n  if (!user) {\n    throw new GraphQLError(\"User not found\", {\n      extensions: { code: \"USER_NOT_FOUND\" },\n    });"},{"id":"delivery_price_service_validatedeliveryavailability","label":"validateDeliveryAvailability()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/services/delivery-price.service.js","source_location":"L242-L260","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/services/delivery-price.service.js","source_location":"L242"}],"snippet":"export async function validateDeliveryAvailability({\n  restaurantId,\n  addressId,\n}) {\n  try {\n    await calculateServerDeliveryPrice({\n      restaurantId,\n      addressId,\n      userId: null,\n    });\n    return { available: true, error: null };\n  } catch (e) {\n    return {\n      available: false,\n      error: e?.message || \"Delivery unavailable\",\n      code: e?.extensions?.code || \"UNKNOWN\",\n    };\n  }\n}"}],"edges":[{"source":"delivery_price_service","target":"graphql","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/services/delivery-price.service.js","source_location":"L19","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/services/delivery-price.service.js","source_location":"L19"}],"weight":1},{"source":"delivery_price_service","target":"zone","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/services/delivery-price.service.js","source_location":"L20","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/services/delivery-price.service.js","source_location":"L20"}],"weight":1},{"source":"delivery_price_service","target":"configuration","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multiv