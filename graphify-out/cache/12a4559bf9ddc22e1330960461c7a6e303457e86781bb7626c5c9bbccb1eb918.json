{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"geoapify","label":"geoapify.js","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L1"}]},{"id":"geoapify_makekey","label":"makeKey()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L36-L42","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L36"}],"snippet":"function makeKey(from, to) {\n  const round = (n) => Math.round(n * 1e5) / 1e5;\n  const a = `${round(from[1])},${round(from[0])}`;\n  const b = `${round(to[1])},${round(to[0])}`;\n  // Всегда сортируем, чтобы A→B == B→A\n  return a < b ? `${a}__${b}` : `${b}__${a}`;\n}"},{"id":"geoapify_makekey_round","label":"round()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L37","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L37"}],"snippet":"round = (n) => Math.round(n * 1e5) / 1e5"},{"id":"geoapify_getcached","label":"getCached()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L44-L52","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L44"}],"snippet":"function getCached(key) {\n  const entry = ROUTE_CACHE.get(key);\n  if (!entry) return null;\n  if (Date.now() - entry.at > CACHE_TTL_MS) {\n    ROUTE_CACHE.delete(key);\n    return null;\n  }\n  return entry;\n}"},{"id":"geoapify_setcached","label":"setCached()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L54-L66","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L54"}],"snippet":"function setCached(key, distanceM) {\n  // ⭐ LRU eviction: если кеш переполнен — удаляем самые старые записи\n  if (ROUTE_CACHE.size >= CACHE_MAX_SIZE) {\n    // Удаляем 10% самых старых (в порядке Map insertion order)\n    const toDelete = Math.floor(CACHE_MAX_SIZE * 0.1);\n    const iter = ROUTE_CACHE.keys();\n    for (let i = 0; i < toDelete; i++) {\n      const k = iter.next().value;\n      if (k) ROUTE_CACHE.delete(k);\n    }\n  }\n  ROUTE_CACHE.set(key, { distanceM, at: Date.now() });\n}"},{"id":"geoapify_fetchroutedistance","label":"fetchRouteDistance()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L76-L145","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L76"}],"snippet":"export async function fetchRouteDistance(from, to, mode = \"scooter\") {\n  if (!GEOAPIFY_API_KEY) {\n    debugWarn(\"Geoapify\", \"API key missing — fallback to Haversine\");\n    return null;\n  }\n  if (!Array.isArray(from) || from.length < 2) return null;\n  if (!Array.isArray(to) || to.length < 2) return null;\n\n  const key = makeKey(from, to);\n  const cached = getCached(key);\n  if (cached) {\n    debugLog(\"Geoapify\", \"cache hit\", {\n      km: (cached.distanceM / 1000).toFixed(2),\n    });\n    return cached.distanceM;\n  }\n\n  const start = Date.now();\n  const url = new URL(GEOAPIFY_BASE);\n  url.searchParams.set(\"waypoints\", `${from[0]},${from[1]}|${to[0]},${to[1]}`);\n  url.searchParams.set(\"mode\", mode);\n  url.searchParams.set(\"apiKey\", GEOAPIFY_API_KEY);\n  url.searchParams.set(\"geometry\", \"false\"); // ⭐ нам не нужен polyline, только distance\n  url.searchParams.set(\"units\", \"meters\");"},{"id":"geoapify_getdistancemeters","label":"getDistanceMeters()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L152-L167","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L152"}],"snippet":"export async function getDistanceMeters(from, to, mode = \"scooter\") {\n  // Сначала проверяем кеш (быстрее всего)\n  const key = makeKey(from, to);\n  const cached = getCached(key);\n  if (cached) return cached.distanceM;\n\n  // Пытаемся через Geoapify\n  const fromApi = await fetchRouteDistance(from, to, mode);\n  if (typeof fromApi === \"number\") return fromApi;\n\n  // Fallback на Haversine\n  debugLog(\"Geoapify\", \"using Haversine fallback\");\n  const [lng1, lat1] = from;\n  const [lng2, lat2] = to;\n  return haversineKm(lat1, lng1, lat2, lng1) * 1000; // → meters\n}"},{"id":"geoapify_fetchroutegeometry","label":"fetchRouteGeometry()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L188-L263","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L188"}],"snippet":"export async function fetchRouteGeometry(from, to, mode = \"scooter\") {\n  if (!GEOAPIFY_API_KEY) return null;\n  if (!Array.isArray(from) || from.length < 2) return null;\n  if (!Array.isArray(to) || to.length < 2) return null;\n\n  const key = makeKey(from, to);\n  const cached = GEOMETRY_CACHE.get(key);\n  if (cached && Date.now() - cached.at < GEOMETRY_CACHE_TTL_MS) {\n    return cached.value;\n  }\n\n  const url = new URL(GEOAPIFY_BASE);\n  url.searchParams.set(\"waypoints\", `${from[0]},${from[1]}|${to[0]},${to[1]}`);\n  url.searchParams.set(\"mode\", mode);\n  url.searchParams.set(\"apiKey\", GEOAPIFY_API_KEY);\n  url.searchParams.set(\"geometry\", \"geojson\"); // ⭐ на этот раз нужна геометрия\n  url.searchParams.set(\"units\", \"meters\");\n\n  try {\n    const controller = new AbortController();\n    const timeoutId = setTimeout(() => controller.abort(), GEOAPIFY_TIMEOUT_MS);\n    const res = await fetch(url.toString(), {\n      method: \"GET\",\n      signal: controller.signal,\n      headers: { Accept: \"application/json\" },"},{"id":"geoapify_getcachestats","label":"getCacheStats()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L268-L275","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L268"}],"snippet":"export function getCacheStats() {\n  return {\n    size: ROUTE_CACHE.size,\n    maxSize: CACHE_MAX_SIZE,\n    ttlMs: CACHE_TTL_MS,\n    apiKeySet: !!GEOAPIFY_API_KEY,\n  };\n}"},{"id":"geoapify_clearroutecache","label":"clearRouteCache()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L280-L282","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L280"}],"snippet":"export function clearRouteCache() {\n  ROUTE_CACHE.clear();\n}"}],"edges":[{"source":"geoapify","target":"geo","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L19","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L19"}],"weight":1},{"source":"geoapify","target":"debug_log","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L20","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L20"}],"weight":1},{"source":"geoapify","target":"geoapify_makekey","relation":"contains","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L36","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L36"}],"weight":1},{"source":"geoapify_makekey","target":"geoapify_makekey_round","relation":"contains","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geoapify.js","source_location":"L37","layer":"base","provenance":[{"capability_id":"builtin:extract:javascri