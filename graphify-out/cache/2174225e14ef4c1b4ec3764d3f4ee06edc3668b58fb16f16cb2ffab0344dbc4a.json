{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"geo","label":"geo.js","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geo.js","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geo.js","source_location":"L1"}]},{"id":"geo_haversinekm","label":"haversineKm()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geo.js","source_location":"L20-L30","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geo.js","source_location":"L20"}],"snippet":"export function haversineKm(lat1, lng1, lat2, lng2) {\n  const R = 6371;\n  const dLat = ((lat2 - lat1) * Math.PI) / 180;\n  const dLng = ((lng2 - lng1) * Math.PI) / 180;\n  const a =\n    Math.sin(dLat / 2) ** 2 +\n    Math.cos((lat1 * Math.PI) / 180) *\n      Math.cos((lat2 * Math.PI) / 180) *\n      Math.sin(dLng / 2) ** 2;\n  return 2 * R * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));\n}"},{"id":"geo_bearingdeg","label":"bearingDeg()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geo.js","source_location":"L36-L47","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geo.js","source_location":"L36"}],"snippet":"export function bearingDeg(lat1, lng1, lat2, lng2) {\n  const toRad = (d) => (d * Math.PI) / 180;\n  const dLng = toRad(lng2 - lng1);\n  const lat1r = toRad(lat1);\n  const lat2r = toRad(lat2);\n  const y = Math.sin(dLng) * Math.cos(lat2r);\n  const x =\n    Math.cos(lat1r) * Math.sin(lat2r) -\n    Math.sin(lat1r) * Math.cos(lat2r) * Math.cos(dLng);\n  const brng = (Math.atan2(y, x) * 180) / Math.PI;\n  return (brng + 360) % 360;\n}"},{"id":"geo_bearingdeg_torad","label":"toRad()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geo.js","source_location":"L37","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geo.js","source_location":"L37"}],"snippet":"toRad = (d) => (d * Math.PI) / 180"},{"id":"geo_pointincircle","label":"pointInCircle()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geo.js","source_location":"L53-L63","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geo.js","source_location":"L53"}],"snippet":"export function pointInCircle(\n  pointLat,\n  pointLng,\n  centerLat,\n  centerLng,\n  radiusM,\n) {\n  const distanceM =\n    haversineKm(pointLat, pointLng, centerLat, centerLng) * 1000;\n  return distanceM <= radiusM;\n}"},{"id":"geo_etaseconds","label":"etaSeconds()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geo.js","source_location":"L71-L74","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geo.js","source_location":"L71"}],"snippet":"export function etaSeconds(distanceKm, avgSpeedKmh = 25, bufferSec = 180) {\n  const travelSec = (distanceKm / avgSpeedKmh) * 3600;\n  return Math.round(travelSec + bufferSec);\n}"},{"id":"geo_sortbydistance","label":"sortByDistance()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geo.js","source_location":"L80-L97","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geo.js","source_location":"L80"}],"snippet":"export function sortByDistance(riderCoords, targetLat, targetLng) {\n  return riderCoords\n    .map((r) => {\n      const coords = r.location?.coordinates || [null, null];\n      const [lng, lat] = coords;\n      const distance =\n        lat != null && lng != null\n          ? haversineKm(lat, lng, targetLat, targetLng)\n          : Infinity;\n      return { ...r, distance };\n    })\n    .sort((a, b) => {\n      if (a.distance === Infinity && b.distance === Infinity) return 0;\n      if (a.distance === Infinity) return 1;\n      if (b.distance === Infinity) return -1;\n      return a.distance - b.distance;\n    });\n}"}],"edges":[{"source":"geo","target":"geo_haversinekm","relation":"contains","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geo.js","source_location":"L20","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geo.js","source_location":"L20"}],"weight":1},{"source":"geo","target":"geo_bearingdeg","relation":"contains","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geo.js","source_location":"L36","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geo.js","source_location":"L36"}],"weight":1},{"source":"geo_bearingdeg","target":"geo_bearingdeg_torad","relation":"contains","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/geo.js"