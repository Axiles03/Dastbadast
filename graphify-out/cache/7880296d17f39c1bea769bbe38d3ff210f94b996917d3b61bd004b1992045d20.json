D_USER_INPUT\" },\n    });\n  }\n  if (!Expo.isExpoPushToken(token)) {\n    throw new GraphQLError(\n      `Некорректный Expo push token: ${token.slice(0, 20)}...`,\n      { extensions: { code: \"BAD_USER_INPUT\" } },\n    );\n  }\n  if (![\"ios\", \"android\"].includes(platform)) {\n    throw new GraphQLError(\"platform должен быть ios или android\", {\n      extensions: { code: \"BAD_USER_INPUT\" },\n    });\n  }\n\n  const { ownerType, ownerId } = requireAuth(ctx);\n\n  const doc = await PushToken.findOneAndUpdate(\n    { token },\n    {\n      $set: {"},{"id":"notifications_unregisterpushtoken","label":"unregisterPushToken()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/notifications.js","source_location":"L76-L81","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/notifications.js","source_location":"L76"}],"snippet":"unregisterPushToken = async (_p, { token }, ctx) => {\n  const { ownerType, ownerId } = requireAuth(ctx);\n  if (!token) return false;\n  const result = await PushToken.deleteOne({ token, ownerType, ownerId });\n  return result.deletedCount > 0;\n}"},{"id":"notifications_mypushtokens","label":"myPushTokens()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/notifications.js","source_location":"L83-L89","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/notifications.js","source_location":"L83"}],"snippet":"myPushTokens = async (_p, _a, ctx) => {\n  const { ownerType, ownerId } = requireAuth(ctx);\n  return PushToken.find({ ownerType, ownerId })\n    .select(\"platform locale lastUsedAt createdAt\")\n    .sort({ createdAt: -1 })\n    .lean();\n}"},{"id":"notifications_getexpo","label":"getExpo()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/notifications.js","source_location":"L96-L103","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/notifications.js","source_location":"L96"}],"snippet":"function getExpo() {\n  if (!_expoInstance) {\n    _expoInstance = new Expo({\n      // accessToken: process.env.EXPO_ACCESS_TOKEN, // optional\n    });\n  }\n  return _expoInstance;\n}"},{"id":"notifications_sendpushtoowner","label":"sendPushToOwner()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/notifications.js","source_location":"L110-L195","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/notifications.js","source_location":"L110"}],"snippet":"export async function sendPushToOwner({\n  ownerType,\n  ownerId,\n  title,\n  body,\n  data = {},\n  ttlSeconds = 3600,\n  sound = \"default\",\n  channelId = \"default\",\n  priority = \"high\",\n  badge,\n}) {\n  if (!ownerId) {\n    debugWarn(\"Push\", \"ownerId missing\");\n    return [];\n  }\n\n  const tokens = await PushToken.find({ ownerType, ownerId, verified: true })\n    .select(\"token\")\n    .lean();\n\n  if (tokens.length === 0) {\n    debugLog(\"Push\", \"no tokens for owner\", { ownerType, ownerId });\n    return [];\n  }"},{"id":"notifications_localize","label":"localize()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/notifications.js","source_location":"L198-L203","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/notifications.js","source_location":"L198"}],"snippet":"export function localize(template, vars) {\n  return Object.entries(vars).reduce(\n    (str, [k, v]) => str.replace(new RegExp(`\\\\{${k}\\\\}`, \"g\"), v),\n    template,\n  );\n}"},{"id":"notifications_shouldsend","label":"shouldSend()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/notifications.js","source_location":"L220-L227","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/notifications.js","source_location":"L220"}],"snippet":"function shouldSend(ownerType, ownerId, eventType, entityId) {\n  const key = `${ownerType}:${ownerId}:${eventType}:${entityId || \"\"}`;\n  const now = Date.now();\n  const last = dedupCache.get(key);\n  if (last && now - last < DEDUP_TTL_MS) return false;\n  dedupCache.set(key, now);\n  return true;\n}"},{"id":"notifications_notify","label":"notify()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/notifications.js","source_location":"L277-L315","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/notifications.js","source_location":"L277"}],"snippet":"async function notify({\n  to,\n  toId,\n  event,\n  vars = {},\n  extra = {},\n  force = false,\n}) {\n  if (!toId) return;\n  const tpl = TEMPLATES[event];\n  if (!tpl) {\n    debugWarn(\"Push\", `unknown event: ${event}`);\n    return;\n  }\n  if (!force && !shouldSend(to, toId, event, vars.orderId)) {\n    debugLog(\"Push\", \"skipped (dedup)\", { to, event });\n    return;\n  }\n  const title = localize(tpl.title, vars);\n  const body = localize(tpl.body, vars);\n  const deepLink = tpl.deepLink ? localize(tpl.deepLink, vars) : null;\n  const data = { ...extra, event, deepLink };\n\n  const ownerType = to === \"user\" ? \"user\" : \"rider\";\n  await sendPushToOwner({"},{"id":"notifications_notifyclientorderpendingtopreparing","label":"notifyClientOrderPendingToPreparing()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/notifications.js","source_location":"L321-L333","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/notifications.js","source_location":"L321"}],"snippet":"export async function notifyClientOrderPendingToPreparing({\n  userId,\n  orderId,\n  orderCode,\n  restaurantName,\n}) {\n  await notify({\n    to: \"user\",\n    toId: userId,\n    event: \"ORDER_PENDING_TO_CLIENT\",\n    vars: { orderId, orderCode, restaurantName },\n  });\n}"},{"id":"notifications_notifyclientorderready","label":"notifyClientOrderReady()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/notifications.js","source_location":"L335-L342","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/notifications.js","source_location":"L335"}],"snippet":"export async function notifyClientOrderReady({ userId, orderId, orderCode }) {\n  await notify({\n    to: \"user\",\n    toId: userId,\n    event: \"ORDER_READY_TO_CLIENT\",\n    vars: { orderId, orderCode },\n  });\n}"},{"id":"notifications_notifyclientorderassigned","label":"notifyClientOrderAssigned()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/notifications.js","source_location":"L344-L355","layer":"base","proven