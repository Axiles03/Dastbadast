{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"delivery_price","label":"delivery-price.js","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/delivery-price.js","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/delivery-price.js","source_location":"L1"}]},{"id":"delivery_price_isvalidcoord","label":"isValidCoord()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/delivery-price.js","source_location":"L47-L60","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/delivery-price.js","source_location":"L47"}],"snippet":"function isValidCoord(v) {\n  if (!Array.isArray(v) || v.length < 2) return false;\n  const [lng, lat] = v;\n  return (\n    typeof lng === \"number\" &&\n    typeof lat === \"number\" &&\n    Number.isFinite(lng) &&\n    Number.isFinite(lat) &&\n    lat >= -90 &&\n    lat <= 90 &&\n    lng >= -180 &&\n    lng <= 180\n  );\n}"},{"id":"delivery_price_distancekmsync","label":"distanceKmSync()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/delivery-price.js","source_location":"L67-L72","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/delivery-price.js","source_location":"L67"}],"snippet":"export function distanceKmSync(from, to) {\n  if (!isValidCoord(from) || !isValidCoord(to)) return null;\n  const [lng1, lat1] = from;\n  const [lng2, lat2] = to;\n  return haversineKm(lat1, lng1, lat2, lng2);\n}"},{"id":"delivery_price_distancekm","label":"distanceKm()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/delivery-price.js","source_location":"L79-L83","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/delivery-price.js","source_location":"L79"}],"snippet":"export async function distanceKm(from, to, mode = \"scooter\") {\n  if (!isValidCoord(from) || !isValidCoord(to)) return null;\n  const meters = await getDistanceMeters(from, to, mode);\n  return meters / 1000;\n}"},{"id":"delivery_price_calculatedeliveryprice","label":"calculateDeliveryPrice()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/delivery-price.js","source_location":"L104-L124","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/delivery-price.js","source_location":"L104"}],"snippet":"export function calculateDeliveryPrice(from, to, opts = {}) {\n  const baseKm = Number.isFinite(opts.baseKm)\n    ? opts.baseKm\n    : DELIVERY_PRICING.baseKm;\n  const basePrice = Number.isFinite(opts.basePrice)\n    ? opts.basePrice\n    : DELIVERY_PRICING.basePrice;\n  const perKmPrice = Number.isFinite(opts.perKmPrice)\n    ? opts.perKmPrice\n    : DELIVERY_PRICING.perKmPrice;\n  const rounding = ROUNDING_FN[opts.rounding] ? opts.rounding : \"exact\";\n  const fn = ROUNDING_FN[rounding];\n\n  const dist = distanceKmSync(from, to);\n  if (dist === null) return basePrice;\n\n  if (dist <= baseKm) return fn(basePrice);\n\n  const extra = (dist - baseKm) * perKmPrice;\n  return fn(basePrice + extra);\n}"},{"id":"delivery_price_calculatedeliverypricebreakdown","label":"calculateDeliveryPriceBreakdown()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/delivery-price.js","source_location":"L142-L177","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/delivery-price.js","source_location":"L142"}],"snippet":"export function calculateDeliveryPriceBreakdown(from, to, opts = {}) {\n  const baseKm = Number.isFinite(opts.baseKm)\n    ? opts.baseKm\n    : DELIVERY_PRICING.baseKm;\n  const basePrice = Number.isFinite(opts.basePrice)\n    ? opts.basePrice\n    : DELIVERY_PRICING.basePrice;\n  const perKmPrice = Number.isFinite(opts.perKmPrice)\n    ? opts.perKmPrice\n    : DELIVERY_PRICING.perKmPrice;\n  const rounding = ROUNDING_FN[opts.rounding] ? opts.rounding : \"exact\";\n  const fn = ROUNDING_FN[rounding];\n\n  const dist = distanceKmSync(from, to);\n  if (dist === null) {\n    return {\n      base: basePrice,\n      perKm: 0,\n      distanceKm: null,\n      total: basePrice,\n      isOverBase: false,\n    };\n  }\n\n  const isOverBase = dist > baseKm;"},{"id":"delivery_price_routedistancekm","label":"routeDistanceKm()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/delivery-price.js","source_location":"L184-L187","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/delivery-price.js","source_location":"L184"}],"snippet":"export function routeDistanceKm(from, to) {\n  const km = distanceKmSync(from, to);\n  return km === null ? 0 : km;\n}"},{"id":"delivery_price_routedistancekmasync","label":"routeDistanceKmAsync()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/delivery-price.js","source_location":"L188-L191","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","so