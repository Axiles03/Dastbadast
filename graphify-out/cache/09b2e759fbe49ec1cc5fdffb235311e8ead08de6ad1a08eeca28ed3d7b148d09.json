 <Pressable\n      onPress={onPress}\n      disabled={disabled}\n      className={cn(\n        \"flex-row items-center gap-3.5 p-4 border-b border-border last:border-0\",\n        disabled ? \"opacity-50\" : \"active:bg-soft-surface-2\",\n      )}\n    >\n      <View","node_kind":"component"},{"id":"profile_computestats","label":"computeStats()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/profile.tsx","source_location":"L435-L458","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/profile.tsx","source_location":"L435"}],"snippet":"function computeStats(allOrders: any[]) {\n  const today = startOfToday();\n  let todayCount = 0;\n  let todayEarnings = 0;\n  let totalCount = 0;\n  let totalEarnings = 0;\n\n  for (const o of allOrders) {\n    if (o.orderStatus !== \"DELIVERED\") continue;\n    totalCount++;\n    totalEarnings += Number(o.amounts?.deliveryFee ?? 0);\n\n    const deliveredAt = o.statusTimestamps?.deliveredAt;\n    const t = deliveredAt\n      ? new Date(deliveredAt).getTime()\n      : new Date(o.createdAt).getTime();\n    if (t >= today) {\n      todayCount++;\n      todayEarnings += Number(o.amounts?.deliveryFee ?? 0);\n    }\n  }\n\n  return { todayCount, todayEarnings, totalCount, totalEarnings };\n}"}],"edges":[{"source":"profile","target":"react","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/profile.tsx","source_location":"L10","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/profile.tsx","source_location":"L10"}],"weight":1},{"source":"profile","target":"react_native","relation":"imports_from","confidence":"EXTRACTE