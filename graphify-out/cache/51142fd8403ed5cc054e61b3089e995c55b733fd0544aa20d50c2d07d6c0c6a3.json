{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"ordercard","label":"OrderCard.tsx","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/OrderCard.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/OrderCard.tsx","source_location":"L1"}]},{"id":"ordercard_pluralize","label":"pluralize()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/OrderCard.tsx","source_location":"L18-L24","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/OrderCard.tsx","source_location":"L18"}],"snippet":"function pluralize(n: number, one: string, few: string, many: string): string {\n  const mod10 = n % 10;\n  const mod100 = n % 100;\n  if (mod10 === 1 && mod100 !== 11) return one;\n  if (mod10 >= 2 && mod10 <= 4 && (mod100 < 12 || mod100 > 14)) return few;\n  return many;\n}"},{"id":"ordercard_geturgency","label":"getUrgency()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/OrderCard.tsx","source_location":"L92-L107","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/OrderCard.tsx","source_location":"L92"}],"snippet":"export function getUrgency(\n  order: Pick<Order, \"orderStatus\" | \"statusTimestamps\">,\n  now: number,\n): Urgency {\n  if (!order || !order.statusTimestamps) return null;\n  if (order.orderStatus !== \"PENDING\" && order.orderStatus !== \"ACCEPTED\")\n    return null;\n  const pendingAt = order.statusTimestamps?.pendingAt;\n  if (!pendingAt) return null;\n  const ageMs = now - new Date(pendingAt).getTime();\n  const escalated =\n    !!order.statusTimestamps?.courierSearchTimestamps?.escalationPushedAt;\n  if (ageMs > 90 * 1000 || escalated) return \"urgent\";\n  if (ageMs > 45 * 1000) return \"warning\";\n  return \"normal\";\n}"},{"id":"ordercard_addressblock","label":"AddressBlock()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/OrderCard.tsx","source_location":"L111-L138","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/OrderCard.tsx","source_location":"L111"}],"snippet":"function AddressBlock({\n  label,\n  name,\n  city,\n  address,\n}: {\n  label: string;\n  name?: string | null;\n  city?: string | null;\n  address?: string | null;\n}) {\n  const line = [city, address].filter(Boolean).join(\", \");\n  return (\n    <View className=\"mt-2.5\">\n      <Text className=\"text-[10px] font-bold text-text-muted uppercase tracking-wider\">\n        {label}\n      </Text>\n      {name ? (\n        <Text className=\"text-sm font-bold text-text mt-0.5\" numberOfLines={1}>\n          {name}\n        </Text>\n      ) : null}\n      <Text className=\"text-sm text-text-soft mt-0.5\" numberOfLines={2}>\n        {line || \"—\"}\n      </Text>","node_kind":"component"},{"id":"ordercard_statusbadge","label":"StatusBadge()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/OrderCard.tsx","source_location":"L140-L173","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/OrderCard.tsx","source_location":"L140"}],"snippet":"function StatusBadge({ status }: { status: string }) {\n  if (status === \"CANCELLED\") return null;\n  const info = STATUS_LABEL[status] ?? {\n    label: status,\n    emoji: \"📦\",\n  };\n  const isDelivering = status === \"PICKED\";\n  const isAwaiting = status === \"AWAITING_CONFIRMATION\";\n  return (\n    <View\n      className={cn(\n        \"rounded-full px-2.5 py-1 border\",\n        isDelivering\n          ? \"bg-info-soft border-info/30\"\n          : isAwaiting\n            ? \"bg-warning-soft border-warning/30\"\n            : \"bg-soft-surface-2 border-border\",\n      )}\n    >\n      <Text\n        className={cn(\n          \"text-xs font-bold\",\n          isDelivering\n            ? \"text-info-dark\"\n            : isAwaiting","node_kind":"component"},{"id":"ordercard_ordercard","label":"OrderCard()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/OrderCard.tsx","source_location":"L207-L352","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/OrderCard.tsx","source_location":"L207"}],"snippet":"export function OrderCard({\n  order,\n  mode,\n  urgency,\n  primaryAction,\n  secondaryAction,\n  onPress,\n  etaMin,\n  etaTarget,\n}: OrderCardProps) {\n  const itemsCount = order.items?.length || 0;\n  const showUrgent = mode === \"pool\" && urgency === \"urgent\";\n  const showWarning = mode === \"pool\" && urgency === \"warning\";\n\n  return (\n    <Pressable\n      onPress={onPress}\n      className={cn(\n        \"bg-soft-surface border rounded-2xl p-4 mb-3 shadow-soft-sm\",\n        // Цвет рамки/фона в зависимости от срочности (только в pool)\n        showUrgent\n          ? \"bg-red-soft border-red border-2\"\n          : showWarning\n            ? \"bg-warning-soft/30 border-warning border-2\"\n            : \"border-border\",","node_kind":"component"}],"edges":[{"source":"ordercard","target":"react","relation":"imports_from","confidence":"EXTRACTED",