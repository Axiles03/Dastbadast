{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"id","label":"[id].tsx","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(app)/orders/[id].tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(app)/orders/[id].tsx","source_location":"L1"}]},{"id":"id_formatcountdown","label":"formatCountdown()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(app)/orders/[id].tsx","source_location":"L105-L111","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(app)/orders/[id].tsx","source_location":"L105"}],"snippet":"function formatCountdown(ms: number): string {\n  if (ms <= 0) return \"00:00\";\n  const totalSec = Math.floor(ms / 1000);\n  const m = Math.floor(totalSec / 60);\n  const s = totalSec % 60;\n  return `${m.toString().padStart(2, \"0\")}:${s.toString().padStart(2, \"0\")}`;\n}"},{"id":"id_haversinekm","label":"haversineKm()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(app)/orders/[id].tsx","source_location":"L113-L128","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(app)/orders/[id].tsx","source_location":"L113"}],"snippet":"function haversineKm(\n  lat1: number,\n  lng1: number,\n  lat2: number,\n  lng2: number,\n): number {\n  const R = 6371;\n  const dLat = ((lat2 - lat1) * Math.PI) / 180;\n  const dLng = ((lng2 - lng1) * Math.PI) / 180;\n  const a =\n    Math.sin(dLat / 2) ** 2 +\n    Math.cos((lat1 * Math.PI) / 180) *\n      Math.cos((lat2 * Math.PI) / 180) *\n      Math.sin(dLng / 2) ** 2;\n  return 2 * R * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));\n}"},{"id":"id_trackingpage","label":"TrackingPage()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(app)/orders/[id].tsx","source_location":"L130-L741","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(app)/orders/[id].tsx","source_location":"L130"}],"snippet":"export default function TrackingPage() {\n  const { id } = useLocalSearchParams<{ id: string }>();\n  const router = useRouter();\n  const [chatOpen, setChatOpen] = useState(false);\n  const [draft, setDraft] = useState(\"\");\n  const [liveMessages, setLiveMessages] = useState<ChatMessage[]>([]);\n  const [timeLeftMs, setTimeLeftMs] = useState<number | null>(null);\n  const [riderPos, setRiderPos] = useState<RiderPos>(null);\n  const [etaMin, setEtaMin] = useState<number | null>(null);\n\n  const { data, loading, error, refetch, subscribeToMore } = useQuery<any>(\n    GET_ORDER,\n    {\n      variables: { id },\n      skip: !id,\n      // pollInterval: 10000  // ⭐ УБРАНО\n    },\n  );\n\n  useEffect(() => {\n    if (!id || !subscribeToMore) return;\n    const unsubscribe = subscribeToMore({\n      document: SUB_ORDER, // ⭐ из lib/queries.ts\n      variables: { orderId: id },\n      updateQuery: (prev: any, { subscriptionData }: any) => {","node_kind":"component"},{"id":"id_trackingpage_tick","label":"tick()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(app)/orders/[id].tsx","source_location":"L278-L281","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(app)/orders/[id].tsx","source_location":"L278"}],"snippet":"tick = () => {\n      const elapsed = Date.now() - new Date(deliveredAt).getTime();\n      setTimeLeftMs(Math.max(0, 30 * 60 * 1000 - elapsed));\n    }"},{"id":"id_minutesword","label":"minutesWord()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(app)/orders/[id].tsx","source_location":"L743-L750","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(app)/orders/[id].tsx","source_location":"L743"}],"snippet":"function minutesWord(n: number) {\n  if (n === 0) return \"\";\n  const mod10 = n % 10;\n  const mod100 = n % 100;\n  if (mod10 === 1 && mod100 !== 11) return \"минута\";\n  if (mod10 >= 2 && mod10 <= 4 && (mod100 < 12 || mod100 > 14)) return \"минуты\";\n  return \"минут\";\n}"},{"id":"id_row","label":"Row()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(app)/orders/[id].tsx","source_location":"L752-L759","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(app)/orders/[id].tsx","source_location":"L752"}],"snippet":"function Row({ label, value }: { label: string; value: string }) {\n  return (\n    <View className=\"flex-row justify-between\">\n      <Text className=\"text-sm text-text-soft\">{label}</Text>\n      <Text className=\"text-sm text-text font-bold\">{value}</Text>\n    </View>\n  );\n}","node_kind":"component"}],"edges":[{"source":"id","target":"react","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(app)/orders/[id].tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-mul