{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"cleanup_cron","label":"cleanup-cron.js","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/cleanup-cron.js","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/cleanup-cron.js","source_location":"L1"}]},{"id":"cleanup_cron_cleanupregistry","label":"cleanupRegistry()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/cleanup-cron.js","source_location":"L23-L56","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/cleanup-cron.js","source_location":"L23"}],"snippet":"function cleanupRegistry({ name, map, ttlMs, maxSize }) {\n  if (!map || map.size === 0) return 0;\n  const now = Date.now();\n  let removed = 0;\n\n  // 1) По TTL\n  for (const [key, value] of map.entries()) {\n    if (value && value.at && now - value.at > ttlMs) {\n      map.delete(key);\n      removed++;\n    }\n  }\n\n  // 2) По размеру (если задан)\n  if (maxSize && map.size > maxSize) {\n    // Удаляем самые старые (в порядке вставки Map сохраняет insertion order)\n    const excess = map.size - maxSize;\n    let i = 0;\n    for (const key of map.keys()) {\n      if (i >= excess) break;\n      map.delete(key);\n      removed++;\n      i++;\n    }\n  }"},{"id":"cleanup_cron_registerregistry","label":"registerRegistry()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/cleanup-cron.js","source_location":"L61-L64","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/cleanup-cron.js","source_location":"L61"}],"snippet":"export function registerRegistry(name, map, ttlMs, maxSize) {\n  registries.push({ name, map, ttlMs, maxSize });\n  debugLog(JOB_NAME, `registered ${name}`, { ttlMs, maxSize });\n}"},{"id":"cleanup_cron_startmemorycleanupjob","label":"startMemoryCleanupJob()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/cleanup-cron.js","source_location":"L66-L91","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/cleanup-cron.js","source_location":"L66"}],"snippet":"export function startMemoryCleanupJob() {\n  if (task) {\n    debugWarn(JOB_NAME, \"already started\");\n    return;\n  }\n  if (process.env.DISABLE_CRON === \"1\") {\n    debugLog(JOB_NAME, \"disabled via env\");\n    return;\n  }\n\n  task = cron.schedule(\n    CRON_EXPR,\n    () => {\n      for (const reg of registries) {\n        try {\n          cleanupRegistry(reg);\n        } catch (e) {\n          debugWarn(JOB_NAME, `cleanup ${reg.name} failed`, e?.message);\n        }\n      }\n    },\n    { scheduled: true, timezone: \"Asia/Dushanbe\" },\n  );\n\n  debugLog(JOB_NAME, \"started\", { expr: CRON_EXPR, count: registries.length });"},{"id":"cleanup_cron_stopmemorycleanupjob","label":"stopMemoryCleanupJob()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/cleanup-cron.js","source_location":"L93-L99","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/cleanup-cron.js","source_location":"L93"}],"snippet":"export function stopMemoryCleanupJob() {\n  if (task) {\n    task.stop();\n    task = null;\n    debugLog(JOB_NAME, \"stopped\");\n  }\n}"}],"edges":[{"source":"cleanup_cron","target":"node_cron","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/cleanup-cron.js","source_location":"L10","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/cleanup-cron.js","source_location":"L10"}],"weight":1},{"source":"cleanup_cron","target":"debug_log","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/cleanup-cron.js","source_location":"L11","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/cleanup-cron.js","source_location":"L11"}],"weight":1},{"source":"cleanup_cron","target":"cleanup_cron_cleanupregistry","relation":"contains","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/cleanup-cron.js","source_location":"L23","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/cleanup-cron.js","source_location":"L23"}],"weight":1},{"source":"cleanup_cron","target":"cleanup_cron_registerregistry","relation":"contains","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/cleanup-cron.js","source_location":"L61","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/cleanup-cron.js","source_location":"L61"}],"weight":1},{"source":"cleanup_cron","target":"cleanup_cron_startmemorycleanupjob","relation":"contains","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/cleanup-cro