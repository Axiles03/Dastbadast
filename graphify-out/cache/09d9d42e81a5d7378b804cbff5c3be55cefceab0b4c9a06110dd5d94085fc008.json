{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"login","label":"login.tsx","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(auth)/login.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(auth)/login.tsx","source_location":"L1"}]},{"id":"login_isvalidemail","label":"isValidEmail()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(auth)/login.tsx","source_location":"L19-L21","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(auth)/login.tsx","source_location":"L19"}],"snippet":"function isValidEmail(s: string) {\n  return /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(s.trim());\n}"},{"id":"login_isvalidphone","label":"isValidPhone()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(auth)/login.tsx","source_location":"L22-L25","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(auth)/login.tsx","source_location":"L22"}],"snippet":"function isValidPhone(s: string) {\n  const clean = s.replace(/[\\s\\-()]/g, \"\");\n  return /^\\+?\\d{9,15}$/.test(clean);\n}"},{"id":"login_isvalidpassword","label":"isValidPassword()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(auth)/login.tsx","source_location":"L26-L28","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(auth)/login.tsx","source_location":"L26"}],"snippet":"function isValidPassword(s: string) {\n  return typeof s === \"string\" && s.length >= 6;\n}"},{"id":"login_login","label":"Login()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(auth)/login.tsx","source_location":"L30-L238","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(auth)/login.tsx","source_location":"L30"}],"snippet":"export default function Login() {\n  const [mode, setMode] = useState<\"login\" | \"register\">(\"login\");\n  const [name, setName] = useState(\"\");\n  const [contact, setContact] = useState(\"\");\n  const [password, setPassword] = useState(\"\");\n\n  // ⭐ useMutation<any>\n  const [doLogin, { loading: lLogin, error: eLogin }] = useMutation<any>(LOGIN);\n  const [doRegister, { loading: lReg, error: eReg }] =\n    useMutation<any>(CREATE_USER);\n  const { setAuth } = useAuth();\n  const router = useRouter();\n\n  const loading = lLogin || lReg;\n  const err = eLogin || eReg;\n\n  const isEmail = useMemo(() => contact.includes(\"@\"), [contact]);\n\n  const clientErrors = useMemo<string[]>(() => {\n    const out: string[] = [];\n    const c = contact.trim();\n    if (!c) out.push(\"Укажите email или телефон\");\n    else if (isEmail && !isValidEmail(c)) out.push(\"Неверный формат email\");\n    else if (!isEmail && !isValidPhone(c))\n      out.push(\"Телефон должен содержать 9–15 цифр (можно с +)\");","node_kind":"component"},{"id":"login_login_submit","label":"submit()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(auth)/login.tsx","source_location":"L67-L97","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(auth)/login.tsx","source_location":"L67"}],"snippet":"submit = async () => {\n    if (!canSubmit) return;\n    try {\n      const c = contact.trim();\n      const baseInput: any = { password };\n      if (isEmail) baseInput.email = c.toLowerCase();\n      else baseInput.phone = c;\n\n      const variables =\n        mode === \"login\"\n          ? { input: baseInput }\n          : { input: { name: name.trim(), ...baseInput } };\n\n      const res =\n        mode === \"login\"\n          ? await doLogin({ variables })\n          : await doRegister({ variables });\n\n      const payload = (res.data as any)?.login ?? (res.data as any)?.createUser;\n      if (payload?.token && payload?.user) {\n        await setAuth(payload.token, payload.user);\n        router.replace(\"/(app)/home\" as any);\n      }\n    } catch (e: any) {\n      let msg = e?.message ?? \"Не удалось выполнить запрос\";"}],"edges":[{"source":"login","target":"react","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(auth)/login.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(auth)/login.tsx","source_location":"L1"}],"weight":1},{"source":"login","target":"react_native","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(auth)/login.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(auth)/login.tsx","source_location":"L2"}],"weight":1},{"source":"login","target":"queries","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-client/app/(auth)/login.tsx","source_locat