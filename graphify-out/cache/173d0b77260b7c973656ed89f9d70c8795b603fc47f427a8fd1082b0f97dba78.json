{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"restaurant","label":"restaurant.js","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/restaurant.js","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/restaurant.js","source_location":"L1"}]},{"id":"restaurant_restaurants","label":"restaurants()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/restaurant.js","source_location":"L4-L8","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/restaurant.js","source_location":"L4"}],"snippet":"restaurants = async (_p, { zoneId }) => {\n  const filter = { isAvailable: true };\n  if (zoneId) filter.zoneId = zoneId;\n  return Restaurant.find(filter).sort({ createdAt: -1 });\n}"},{"id":"restaurant_isobjectid","label":"isObjectId()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/restaurant.js","source_location":"L10-L12","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/restaurant.js","source_location":"L10"}],"snippet":"function isObjectId(str) {\n  return typeof str === \"string\" && /^[a-f0-9]{24}$/i.test(str);\n}"},{"id":"restaurant_restaurant","label":"restaurant()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/restaurant.js","source_location":"L14-L32","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/restaurant.js","source_location":"L14"}],"snippet":"restaurant = async (_p, { id }) => {\n  if (!id) return null;\n  const key = String(id).trim();\n  if (!key) return null;\n\n  if (isObjectId(key)) {\n    try {\n      const byId = await Restaurant.findById(key);\n      if (byId) return byId;\n    } catch {\n      /* упало — едем дальше к slug */\n    }\n  }\n\n  const bySlug = await Restaurant.findOne({ slug: key });\n  if (bySlug) return bySlug;\n\n  return null;\n}"},{"id":"restaurant_isrestaurantopennow","label":"isRestaurantOpenNow()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/restaurant.js","source_location":"L36-L48","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/restaurant.js","source_location":"L36"}],"snippet":"export function isRestaurantOpenNow(r) {\n  if (r.workingHours?.isAlwaysOpen) return true;\n  if (!r.workingHours?.open || !r.workingHours?.close) return true;\n  const now = new Date();\n  const [oh, om] = r.workingHours.open.split(\":\").map(Number);\n  const [ch, cm] = r.workingHours.close.split(\":\").map(Number);\n  const nowMin = now.getHours() * 60 + now.getMinutes();\n  const openMin = oh * 60 + om;\n  const closeMin = ch * 60 + cm;\n  return closeMin > openMin\n    ? nowMin >= openMin && nowMin < closeMin\n    : nowMin >= openMin || nowMin < closeMin; // ночная смена через полночь\n}"}],"edges":[{"source":"restaurant","target":"restaurant","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/restaurant.js","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastb