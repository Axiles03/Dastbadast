 input }) => {\n  if (!input.email && !input.phone) {\n    throw new GraphQLError(\"Нужен email или телефон\", {\n      extensions: { code: \"BAD_USER_INPUT\" },\n    });\n  }\n  const passwordHash = await bcrypt.hash(input.password, 10);\n  const or = [];\n  if (input.email) or.push({ email: input.email.toLowerCase() });\n  if (input.phone) or.push({ phone: input.phone });\n  const exists = await User.findOne({ $or: or });\n  if (exists)\n    throw new GraphQLError(\"Пользователь уже существует\", {\n      extensions: { code: \"CONFLICT\" },\n    });\n\n  const user = await User.create({\n    name: input.name,\n    email: input.email?.toLowerCase(),\n    phone: input.phone,\n    passwordHash,\n  });\n  const token = signToken(user);\n  return { token, user };\n}"},{"id":"user_login","label":"login()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L73-L94","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L73"}],"snippet":"login = async (_p, { input }) => {\n  if (!input.email && !input.phone) {\n    throw new GraphQLError(\"Нужен email или телефон\", {\n      extensions: { code: \"BAD_USER_INPUT\" },\n    });\n  }\n  const query = input.email\n    ? { email: input.email.toLowerCase() }\n    : { phone: input.phone };\n  const user = await User.findOne(query);\n  if (!user)\n    throw new GraphQLError(\"Неверные данные\", {\n      extensions: { code: \"UNAUTHENTICATED\" },\n    });\n  const ok = await bcrypt.compare(input.password, user.passwordHash);\n  if (!ok)\n    throw new GraphQLError(\"Неверные данные\", {\n      extensions: { code: \"UNAUTHENTICATED\" },\n    });\n  const token = signToken(user);\n  return { token, user };\n}"},{"id":"user_validatepoint","label":"validatePoint()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L96-L126","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L96"}],"snippet":"async function validatePoint(location) {\n  const coords = location?.coordinates;\n  if (!Array.isArray(coords) || coords.length !== 2) {\n    throw new GraphQLError(\"Некорректные координаты\", {\n      extensions: { code: \"BAD_USER_INPUT\" },\n    });\n  }\n  const [lng, lat] = coords.map(Number);\n  if (Number.isNaN(lng) || Number.isNaN(lat)) {\n    throw new GraphQLError(\"Некорректные координаты\", {\n      extensions: { code: \"BAD_USER_INPUT\" },\n    });\n  }\n  const zone = await Zone.findOne({ isActive: true });\n  if (!zone) {\n    throw new GraphQLError(\n      \"Зона доставки не настроена. Запустите npm run seed на API.\",\n      {\n        extensions: { code: \"ZONE_NOT_CONFIGURED\" },\n      },\n    );\n  }\n  const poly = zone.location?.coordinates?.[0];\n  if (!poly || !pointInPolygon([lng, lat], poly)) {\n    throw new GraphQLError("},{"id":"user_createaddress","label":"createAddress()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L128-L151","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L128"}],"snippet":"createAddress = async (_p, { input }, ctx) => {\n  const u = requireUser(ctx);\n  const { lng, lat } = await validatePoint(input.location);\n  const user = await User.findById(u._id);\n  if ((user.addresses?.length || 0) >= 3) {\n    throw new GraphQLError(\"Можно сохранить не более 3 адресов\", {\n      extensions: { code: \"ADDRESS_LIMIT\" },\n    });\n  }\n  const makeSelected = !user.addresses || user.addresses.length === 0;\n  if (makeSelected) {\n    user.addresses.forEach((a) => (a.isSelected = false));\n  }\n  user.addresses.push({\n    label: input.label || \"Дом\",\n    address: input.address,\n    city: input.city || \"Душанбе\",\n    details: input.details || \"\",\n    location: { type: \"Point\", coordinates: [lng, lat] },\n    isSelected: makeSelected,\n  });\n  await user.save();\n  return user.addresses[user.addresses.length - 1];\n}"},{"id":"user_editaddress","label":"editAddress()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L153-L166","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L153"}],"snippet":"editAddress = async (_p, { id, input }, ctx) => {\n  const u = requireUser(ctx);\n  const { lng, lat } = await validatePoint(input.location);\n  const user = await User.findById(u._id);\n  const addr = user.addresses.id(id);\n  if (!addr) throw new GraphQLError(\"Адрес не найден\");\n  addr.label = input.label || addr.label;\n  addr.address = input.address;\n  addr.city = input.city || addr.city;\n  addr.details = input.details ?? addr.details;\n  addr.location = { type: \"Point\", coordinates: [lng, lat] };\n  await user.save();\n  return addr;\n}"},{"id":"user_deleteaddress","label":"deleteAddress()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L168-L180","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L168"}],"snippet":"deleteAddress = async (_p, { id }, ctx) => {\n  const u = requireUser(ctx);\n  const user = await User.findById(u._id);\n  const addr = user.addresses.id(id);\n  if (!addr) return false;\n  const wasSelected = addr.isSelected;\n  addr.deleteOne();\n  if (wasSelected && user.addresses.length > 0) {\n    user.addresses[0].isSelected = true;\n  }\n  await user.save();\n  return true;\n}"},{"id":"user_selectaddress","label":"selectAddress()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L182-L192","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L182"}],"snippet":"selectAddress = async (_p, { id }, ctx) => {\n  const u = requireUser(ctx);\n  const user = await User.findById(u._id);\n  let found = null;\n  user.addresses.forEach((a) => {\n    a.isSelected = a._id.toString() === id;\n    if (a.isSelected) found = a;\n  });\n  await user.save();\n  return found;\n}"},{"id":"user_adminusers","label":"adminUsers()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L196-L248","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L196"}],"snippet":"adminUsers = async (_p, { filter }, ctx) => {\n  requireRole([\"SUPER_ADMIN\", \"SUPPORT\"])(ctx);\n\n  const q = filter?.search?.trim() || \"\";\n  const limit = Math.min(filter?.limit || 50, 200);\n  const offset = filter?.offset || 0;\n\n  const mongoFilter = {};\n  if (q) {\n    const re = new RegExp(q.replace(/[.*+?^${}()|[\\]\\\\]/g, \"\\\\$&\"), \"i\");\n    mongoFilter.$or = [{ name: re }, { email: re }, { phone: re }];\n  }\n\n  const total = await User.countDocuments(mongoFilter);\n  const users = await User.find(mongoFilter)\n    .select(\"name email phone isActive createdAt addresses\")\n    .sort({ createdAt: -1 })\n    .skip(offset)\n    .limit(limit);\n\n  const userIds = users.map((u) => u._id);\n  const orderStats = await Order.aggregate([\n    { $match: { userId: { $in: userIds } } },\n    {\n      $group: {"},{"id":"user_adminuserdetail","label":"adminUserDetail()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L250-L298","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L250"}],"snippet":"adminUserDetail = async (_p, { id }, ctx) => {\n  requireRole([\"SUPER_ADMIN\", \"SUPPORT\"])(ctx);\n\n  if (!mongoose.isValidObjectId(id)) {\n    throw new GraphQLError(\"Некорректный id\", {\n      extensions: { code: \"BAD_USER_INPUT\" },\n    });\n  }\n\n  const user = await User.findById(id);\n  if (!user) {\n    throw new GraphQLError(\"Пользователь не найден\", {\n      extensions: { code: \"NOT_FOUND\" },\n    });\n  }\n\n  const orders = await Order.find({ userId: user._id })\n    .sort({ createdAt: -1 })\n    .limit(20)\n    .populate(\"restaurantId\", \"name\")\n    .lean();\n\n  return {\n    user: {\n      id: user._id.toString(),"},{"id":"user_toggleuseractive","label":"toggleUserActive()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L300-L323","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L300"}],"snippet":"toggleUserActive = async (_p, { id, isActive }, ctx) => {\n  requireRole([\"SUPER_ADMIN\", \"SUPPORT\"])(ctx);\n\n  if (!mongoose.isValidObjectId(id)) {\n    throw new GraphQLError(\"Некорректный id\", {\n      extensions: { code: \"BAD_USER_INPUT\" },\n    });\n  }\n\n  const user = await User.findById(id);\n  if (!user) {\n    throw new GraphQLError(\"Пользователь не найден\", {\n      extensions: { code: \"NOT_FOUND\" },\n    });\n  }\n\n  user.isActive = !!isActive;\n  await user.save();\n\n  return {\n    id: user._id.toString(),\n    isActive: user.isActive,\n  };\n}"},{"id":"user_updateuser","label":"updateUser()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L325-L382","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L325"}],"snippet":"updateUser = async (_p, { input }, ctx) => {\n  const current = requireUser(ctx);\n\n  // 1) Валидация телефона, если передан\n  if (input.phone !== undefined && input.phone !== null && input.phone !== \"\") {\n    const cleaned = String(input.phone).replace(/[\\s\\-()]/g, \"\");\n    if (!TJ_PHONE_REGEX.test(cleaned)) {\n      throw new GraphQLError(\n        \"Телефон должен быть в формате +992 и ровно 9 цифр (например +992901234567)\",\n        { extensions: { code: \"BAD_USER_INPUT\" } },\n      );\n    }\n    input.phone = cleaned;\n  }\n\n  const user = await User.findById(current._id);\n  if (!user) {\n    throw new GraphQLError(\"Пользователь не найден\", {\n      extensions: { code: \"NOT_FOUND\" },\n    });\n  }\n\n  // 2) Применяем изменения\n  if (input.name !== undefined) {\n    const name = String(input.name).trim();"},{"id":"user_userltv","label":"userLTV()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L390-L491","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L390"}],"snippet":"userLTV = async (_p, { userId }, ctx) => {\n  requireRole([\"SUPER_ADMIN\", \"FINANCE\", \"ANALYST\", \"SUPPORT\"])(ctx);\n\n  if (!mongoose.isValidObjectId(userId)) {\n    throw new GraphQLError(\"Некорректный id\", {\n      extensions: { code: \"BAD_USER_INPUT\" },\n    });\n  }\n\n  const stats = await Order.aggregate([\n    { $match: { userId: new mongoose.Types.ObjectId(userId) } },\n    {\n      $facet: {\n        delivered: [\n          { $match: { orderStatus: \"DELIVERED\" } },\n          {\n            $group: {\n              _id: null,\n              totalSpent: { $sum: \"$amounts.total\" },\n              count: { $sum: 1 },\n              firstDelivered: { $min: \"$statusTimestamps.deliveredAt\" },\n              lastDelivered: { $max: \"$statusTimestamps.deliveredAt\" },\n            },\n          },\n        ],"},{"id":"user_userorderfrequency","label":"userOrderFrequency()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L496-L598","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/user.js","source_location":"L496"}],"snippet":"userOrderFrequency = async (_p, { userId }, ctx) => {\n  requireRole([\"SUPER_ADMIN\", \"FINANCE\", \"ANALYST\", \"SUPPORT\"])(ctx);\n\n  if (!mongoose.isValidObjectId(userId)) {\n    throw new GraphQLError(\"Некорректный id\", {\n      extensions: { code: \"BAD_USER_INPUT\" },\n    });\n  }\n\n  const orders = await Order.find({ userId })\n    .select(\"orderStatus createdAt\")\n    .sort({ createdAt: 1 })\n    .lean();\n\n  if (orders.length === 0) {\n    retu