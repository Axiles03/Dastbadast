{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"edit_profile","label":"edit-profile.tsx","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/edit-profile.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/edit-profile.tsx","source_location":"L1"}]},{"id":"edit_profile_editprofilescreen","label":"EditProfileScreen()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/edit-profile.tsx","source_location":"L41-L326","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/edit-profile.tsx","source_location":"L41"}],"snippet":"export default function EditProfileScreen() {\n  const router = useRouter();\n  const { rider, updateRider } = useAuth();\n\n  const [name, setName] = useState(rider?.name ?? \"\");\n  const [phone, setPhone] = useState(rider?.phone ?? \"\");\n  const [email, setEmail] = useState(rider?.email ?? \"\");\n  const [photo, setPhoto] = useState<string | null>(rider?.photo ?? null);\n  const [pickingPhoto, setPickingPhoto] = useState(false);\n\n  const [showPasswordForm, setShowPasswordForm] = useState(false);\n  const [oldPassword, setOldPassword] = useState(\"\");\n  const [newPassword, setNewPassword] = useState(\"\");\n  const [confirmPassword, setConfirmPassword] = useState(\"\");\n\n  const [updateProfile, { loading: savingProfile }] =\n    useMutation<any>(UPDATE_RIDER_PROFILE);\n  const [changePassword, { loading: savingPassword }] = useMutation<any>(\n    CHANGE_RIDER_PASSWORD,\n  );\n\n  const pickPhoto = async () => {\n    setPickingPhoto(true);\n    try {\n      // Ленивый импорт — чтобы файл не падал, если зависимость ещё не","node_kind":"component"},{"id":"edit_profile_editprofilescreen_pickphoto","label":"pickPhoto()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/edit-profile.tsx","source_location":"L62-L95","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/edit-profile.tsx","source_location":"L62"}],"snippet":"pickPhoto = async () => {\n    setPickingPhoto(true);\n    try {\n      // Ленивый импорт — чтобы файл не падал, если зависимость ещё не\n      // установлена, а просто показывал понятную ошибку.\n      const ImagePicker = await import(\"expo-image-picker\");\n      const perm = await ImagePicker.requestMediaLibraryPermissionsAsync();\n      if (!perm.granted) {\n        Alert.alert(\n          \"Нет доступа\",\n          \"Разрешите доступ к галерее, чтобы выбрать фото профиля.\",\n        );\n        return;\n      }\n      const result = await ImagePicker.launchImageLibraryAsync({\n        mediaTypes: ImagePicker.MediaTypeOptions.Images,\n        allowsEditing: true,\n        aspect: [1, 1],\n        quality: 0.6,\n        base64: true,\n      });\n      if (result.canceled || !result.assets?.[0]?.base64) return;\n      const asset = result.assets[0];\n      const mime = asset.mimeType || \"image/jpeg\";\n      setPhoto(`data:${mime};base64,${asset.base64}`);"},{"id":"edit_profile_editprofilescreen_handlesaveprofile","label":"handleSaveProfile()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/edit-profile.tsx","source_location":"L97-L122","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/edit-profile.tsx","source_location":"L97"}],"snippet":"handleSaveProfile = async () => {\n    try {\n      const { data } = await updateProfile({\n        variables: {\n          input: {\n            name: name.trim(),\n            phone: phone.trim(),\n            email: email.trim(),\n            photo: photo ?? \"\",\n          },\n        },\n      });\n      const updated = data?.updateRiderProfile;\n      if (updated) {\n        await updateRider({\n          name: updated.name,\n          phone: updated.phone,\n          email: updated.email,\n          photo: updated.photo,\n        });\n      }\n      Alert.alert(\"Готово\", \"Профиль обновлён\");\n    } catch (e: any) {\n      Alert.alert(\"Ошибка\", e?.message ?? \"Не удалось сохранить профиль\");\n    }"},{"id":"edit_profile_editprofilescreen_handlechangepassword","label":"handleChangePassword()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/edit-profile.tsx","source_location":"L124-L145","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/edit-profile.tsx","source_location":"L124"}],"snippet":"handleChangePassword = async () => {\n    if (newPassword.length < 6) {\n      Alert.alert(\"Слишком короткий пароль\", \"Минимум 6 символов\");\n      return;\n    }\n    if (newPassword !== confirmPassword) {\n      Alert.alert(\"Пароли не совпадают\");\n      return;\n    }\n    try {\n      await changePassword({\n        variables: { input: { oldPassword, newPassword } },\n      });\n      setOldPassword(\"\");\n      setNewPassword(\"\");\n      setConfirmPassword(\"\");\n      setShowPasswordForm(false);\n      Alert.alert(\"Готово\", \"Пароль изменён\");\n    } catch (e: any) {\n      Alert.alert(\"Ошибка\", e?.message ?? \"Не удалось изменить пароль\");\n    }\n  }"},{"id":"edit_profile_editprofilescreen_handleforgotpassword","label":"handleForgotPassword()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/edit-profile.tsx","source_location":"L147-L154","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/edit-profile.tsx","source_location":"L147"}],"snippet":"handleForgotPassword = () => {\n    // ⭐ ЗАГЛУШКА: позже — восстановление через Google-аккаунт или\n    // подтверждение по номеру телефона (SMS-код). Пока просто сообщаем.\n    Alert.alert(\n      \"Скоро\",\n      \"Восстановление пароля через Google или номер телефона появится в одном из следующих обновлений. Пока обратитесь в поддержку: support@dastbadast.tj\",\n    );\n  }"},{"id":"edit_profile_field","label":"Field()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/edit-profile.tsx","source_location":"L330-L348","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/edit-profile.tsx","source_location":"L330"}],"snippet":"function Field({\n  label,\n  ...inputProps\n}: {\n  label: string;\n} & ComponentProps<typeof TextInput>) {\n  return (\n    <View>\n      <Text className=\"text-2xs font-bold text-text-soft uppercase tracking-wider mb-1.5\">\n        {label}\n      </Text>\n      <TextInput\n        {...inputProps}\n        placeholderTextColor=\"#9C9284\"\n        className=\"h-12 px-4 bg-soft-surface-2 border border-border rounded-2xl text-sm text-text font-semibold\"\n      />\n    </View>\n  );\n}","node_kind":"component"}],"edges":[{"source":"edit_profile","target":"react","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/edit-profile.tsx","source_location":"L19","layer":"base","provenance":[{"capability_id":