{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"chat","label":"chat.js","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/chat.js","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/chat.js","source_location":"L1"}]},{"id":"chat_canaccessorder","label":"canAccessOrder()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/chat.js","source_location":"L15-L44","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/chat.js","source_location":"L15"}],"snippet":"async function canAccessOrder(ctx, orderId) {\n  const order = await Order.findById(orderId);\n  if (!order) {\n    throw new GraphQLError(\"Заказ не найден\", {\n      extensions: { code: \"NOT_FOUND\" },\n    });\n  }\n  if (ctx.user) {\n    if (order.userId.toString() !== ctx.user._id.toString()) {\n      throw new GraphQLError(\"Нет доступа к чату\", {\n        extensions: { code: \"FORBIDDEN\" },\n      });\n    }\n    return { order, senderType: \"USER\", senderId: ctx.user._id.toString() };\n  }\n  if (ctx.rider) {\n    if (\n      !order.riderId ||\n      order.riderId.toString() !== ctx.rider._id.toString()\n    ) {\n      throw new GraphQLError(\"Нет доступа к чату\", {\n        extensions: { code: \"FORBIDDEN\" },\n      });\n    }\n    return { order, senderType: \"RIDER\", senderId: ctx.rider._id.toString() };"},{"id":"chat_chatmessages","label":"chatMessages()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/chat.js","source_location":"L46-L49","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/chat.js","source_location":"L46"}],"snippet":"chatMessages = async (_p, { orderId }, ctx) => {\n  await canAccessOrder(ctx, orderId);\n  return ChatMessage.find({ orderId }).sort({ createdAt: 1 }).limit(500);\n}"},{"id":"chat_sendchatmessage","label":"sendChatMessage()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/chat.js","source_location":"L51-L75","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/chat.js","source_location":"L51"}],"snippet":"sendChatMessage = async (_p, { orderId, text }, ctx) => {\n  const trimmed = (text || \"\").trim();\n  if (!trimmed) {\n    throw new GraphQLError(\"Пустое сообщение\", {\n      extensions: { code: \"BAD_USER_INPUT\" },\n    });\n  }\n  const { order, senderType, senderId } = await canAccessOrder(ctx, orderId);\n\n  if (!ALLOWED_STATUSES.includes(order.orderStatus)) {\n    throw new GraphQLError(\"Чат доступен только после назначения курьера\", {\n      extensions: { code: \"BAD_STATE\" },\n    });\n  }\n\n  const msg = await ChatMessage.create({\n    orderId,\n    senderType,\n    senderId,\n    text: trimmed,\n  });\n  const payload = { newChatMessage: msg };\n  pubsub.publish(TOPICS.CHAT(orderId.toString()), payload);\n  return msg;\n}"}],"edges":[{"source":"chat","target":"graphql","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/chat.js","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/chat.js","source_location":"L1"}],"weight":1},{"source":"cha