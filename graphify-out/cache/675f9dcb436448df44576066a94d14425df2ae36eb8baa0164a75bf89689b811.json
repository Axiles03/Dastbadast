{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"food_review","label":"food-review.js","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/food-review.js","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/food-review.js","source_location":"L1"}]},{"id":"food_review_requireuser","label":"requireUser()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/food-review.js","source_location":"L6-L9","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/food-review.js","source_location":"L6"}],"snippet":"function requireUser(ctx) {\n  if (!ctx.user) throw new GraphQLError('Not authenticated', { extensions: { code: 'UNAUTHENTICATED' } });\n  return ctx.user;\n}"},{"id":"food_review_foodreviews","label":"foodReviews()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/food-review.js","source_location":"L11-L13","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/food-review.js","source_location":"L11"}],"snippet":"foodReviews = async (_p, { foodId }) => {\n  return FoodReview.find({ foodId }).sort({ createdAt: -1 }).limit(50);\n}"},{"id":"food_review_addfoodreview","label":"addFoodReview()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/food-review.js","source_location":"L15-L46","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/food-review.js","source_location":"L15"}],"snippet":"addFoodReview = async (_p, { input }, ctx) => {\n  const u = requireUser(ctx);\n  const food = await Food.findById(input.foodId);\n  if (!food || !food.isActive) {\n    throw new GraphQLError('Блюдо не найдено', { extensions: { code: 'NOT_FOUND' } });\n  }\n  const rating = Math.round(Number(input.rating));\n  if (!Number.isFinite(rating) || rating < 1 || rating > 5) {\n    throw new GraphQLError('Рейтинг от 1 до 5', { extensions: { code: 'BAD_USER_INPUT' } });\n  }\n  const comment = (input.comment || '').trim();\n  if (!comment) {\n    throw new GraphQLError('Напишите комментарий к отзыву', { extensions: { code: 'BAD_USER_INPUT' } });\n  }\n  const User = (await import('../models/User.js')).User;\n  const user = await User.findById(u._id);\n  const existing = await FoodReview.findOne({ foodId: food._id, userId: u._id });\n  if (existing) {\n    existing.rating = rating;\n    existing.comment = comment;\n    existing.userName = user?.name || '';\n    await existing.save();\n    return existing;\n  }\n  return FoodReview.create({"},{"id":"food_review_foodratingstats","label":"foodRatingStats()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/food-review.js","source_location":"L48-L59","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/food-review.js","source_location":"L48"}],"snippet":"export async function foodRatingStats(foodId) {\n  const oid = typeof foodId === 'string' ? new mongoose.Types.ObjectId(foodId) : foodId;\n  const rows = await FoodReview.aggregate([\n    { $match: { foodId: oid } },\n    { $group: { _id: null, avg: { $avg: '$rating' }, count: { $sum: 1 } } },\n  ]);\n  if (!rows.length) return { averageRating: 0, reviewCount: 0 };\n  return {\n    averageRating: +rows[0].avg.toFixed(1),\n    reviewCount: rows[0].count,\n  };\n}"}],"edges":[{"source":"food_review","target":"mongoose","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/food-review.js","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/food-review.js","source_location":"L1"}],"weight":1},{"source":"food_review","target":"graphql","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/food-review.js","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/food-review.js","source_location":"L2"}],"weight":1},{"source":"food_review","target":"foodreview","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/food-review.js","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/food-review.js","source_location":"L3"}],"weight":1},{"source":"food_review","target":"food","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/food-review.js","source_location":"L4","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/food-review.js","source_location":"L4"}],"weight"