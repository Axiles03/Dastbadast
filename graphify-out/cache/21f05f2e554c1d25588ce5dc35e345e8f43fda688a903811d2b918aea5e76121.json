{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"rider","label":"rider.js","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L1"}]},{"id":"rider_publicriderprofile","label":"publicRiderProfile()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L24-L30","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L24"}],"snippet":"function publicRiderProfile(rider) {\n  if (!rider) return null;\n  // Принудительно обнуляем GPS для не-админов и не-владельца\n  rider.location = { type: \"Point\", coordinates: [0, 0] };\n  rider.lastLocationAt = null;\n  return rider;\n}"},{"id":"rider_requirerider","label":"requireRider()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L32-L38","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L32"}],"snippet":"function requireRider(ctx) {\n  if (!ctx.rider)\n    throw new GraphQLError(\"Not authenticated\", {\n      extensions: { code: \"UNAUTHENTICATED\" },\n    });\n  return ctx.rider;\n}"},{"id":"rider_haversinekm","label":"haversineKm()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L41-L51","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L41"}],"snippet":"function haversineKm(lat1, lng1, lat2, lng2) {\n  const R = 6371;\n  const dLat = ((lat2 - lat1) * Math.PI) / 180;\n  const dLng = ((lng2 - lng1) * Math.PI) / 180;\n  const a =\n    Math.sin(dLat / 2) ** 2 +\n    Math.cos((lat1 * Math.PI) / 180) *\n      Math.cos((lat2 * Math.PI) / 180) *\n      Math.sin(dLng / 2) ** 2;\n  return 2 * R * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));\n}"},{"id":"rider_updateriderlocation","label":"updateRiderLocation()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L53-L180","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L53"}],"snippet":"updateRiderLocation = async (_p, { input }, ctx) => {\n  const r = requireRider(ctx);\n  const { lat, lng, bearing } = input;\n\n  // 1) Валидация (без изменений)\n  if (\n    typeof lat !== \"number\" ||\n    typeof lng !== \"number\" ||\n    lat < -90 ||\n    lat > 90 ||\n    lng < -180 ||\n    lng > 180\n  ) {\n    throw new GraphQLError(\"Некорректные координаты\", {\n      extensions: { code: \"BAD_USER_INPUT\" },\n    });\n  }\n\n  // 2) Throttling: 10 сек (без изменений)\n  const now = Date.now();\n  const prev = lastRiderLocation.get(r._id.toString());\n  if (prev && now - prev.at < RIDER_LOCATION_THROTTLE_MS) {\n    return r;\n  }"},{"id":"rider_stopriderlocationstream","label":"stopRiderLocationStream()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L183-L195","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L183"}],"snippet":"stopRiderLocationStream = async (_p, _a, ctx) => {\n  const r = requireRider(ctx);\n  lastRiderLocation.delete(r._id.toString());\n  // Сигнализируем клиентам, что стрим остановлен\n  pubsub.publish(TOPICS.RIDER_LOCATION(r._id.toString()), {\n    subscriptionRiderLocation: {\n      riderId: r._id.toString(),\n      stopped: true,\n      updatedAt: new Date().toISOString(),\n    },\n  });\n  return true;\n}"},{"id":"rider_riderlogin","label":"riderLogin()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L197-L210","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L197"}],"snippet":"riderLogin = async (_p, { input }) => {\n  const r = await Rider.findOne({ username: input.username, isActive: true });\n  if (!r)\n    throw new GraphQLError(\"Неверные данные\", {\n      extensions: { code: \"UNAUTHENTICATED\" },\n    });\n  const ok = await bcrypt.compare(input.password, r.passwordHash);\n  if (!ok)\n    throw new GraphQLError(\"Неверные данные\", {\n      extensions: { code: \"UNAUTHENTICATED\" },\n    });\n  const token = signRiderToken(r);\n  return { token, rider: r };\n}"},{"id":"rider_merider","label":"meRider()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L212","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L212"}],"snippet":"meRider = async (_p, _a, ctx) => requireRider(ctx)"},{"id":"rider_riderorders","label":"riderOrders()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L214-L219","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L214"}],"snippet":"riderOrders = async (_p, { status }, ctx) => {\n  const r = requireRider(ctx);\n  const filter = { riderId: r._id };\n  if (status) filter.orderStatus = status;\n  return Order.find(filter).sort({ createdAt: -1 });\n}"},{"id":"rider_availableordersforriders","label":"availableOrdersForRiders()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L225-L232","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L225"}],"snippet":"availableOrdersForRiders = async (_p, _a, ctx) => {\n  const r = requireRider(ctx);\n  const baseFilter = { orderStatus: \"ACCEPTED\", riderId: null };\n  if (r.zoneId) {\n    baseFilter.zoneId = r.zoneId;\n  }\n  return Order.find(baseFilter).sort({ createdAt: 1 }).limit(50);\n}"},{"id":"rider_claimorder","label":"claimOrder()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L234-L284","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L234"}],"snippet":"claimOrder = async (_p, { orderId }, ctx) => {\n  const r = requireRider(ctx);\n  if (!r.available) {\n    throw new GraphQLError(\"Включите статус «Доступен», чтобы брать заказы\", {\n      extensions: { code: \"RIDER_UNAVAILABLE\" },\n    });\n  }\n  const active = await Order.countDocuments({\n    riderId: r._id,\n    orderStatus: { $in: [\"ASSIGNED\", \"PICKED\"] },\n  });\n  if (active > 0) {\n    throw new GraphQLError(\"Сначала завершите текущий заказ\", {\n      extensions: { code: \"BAD_STATE\" },\n    });\n  }\n\n  const order = await Order.findOneAndUpdate(\n    { _id: orderId, orderStatus: \"ACCEPTED\", riderId: null },\n    {\n      $set: {\n        riderId: r._id,\n        orderStatus: \"ASSIGNED\",\n        \"statusTimestamps.assignedAt\": new Date(),\n      },"},{"id":"rider_updateorderstatusrider","label":"updateOrderStatusRider()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L292-L339","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L292"}],"snippet":"updateOrderStatusRider = async (_p, { input }, ctx) => {\n  const r = requireRider(ctx);\n  const order = await Order.findById(input.orderId);\n  if (!order)\n    throw new GraphQLError(\"Заказ не найден\", {\n      extensions: { code: \"NOT_FOUND\" },\n    });\n  if (!order.riderId || order.riderId.toString() !== r._id.toString()) {\n    throw new GraphQLError(\"Заказ не назначен вам\", {\n      extensions: { code: \"FORBIDDEN\" },\n    });\n  }\n\n  if (![\"PICKED\", \"AWAITING_CONFIRMATION\"].includes(input.status)) {\n    throw new GraphQLError(\n      \"Курьер может выставить PICKED или AWAITING_CONFIRMATION. Финальный DELIVERED ставится только клиентом.\",\n      { extensions: { code: \"BAD_USER_INPUT\" } },\n    );\n  }\n  if (!ALLOWED[input.status].includes(order.orderStatus)) {\n    throw new GraphQLError(\n      `Невозможно перевести в ${input.status} из ${order.orderStatus}`,\n      { extensions: { code: \"BAD_STATE\" } },\n    );\n  }"},{"id":"rider_togglerider","label":"toggleRider()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L341-L346","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L341"}],"snippet":"toggleRider = async (_p, { available }, ctx) => {\n  const r = requireRider(ctx);\n  r.available = !!available;\n  await r.save();\n  return r;\n}"},{"id":"rider_updateriderprofile","label":"updateRiderProfile()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L357-L388","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L357"}],"snippet":"updateRiderProfile = async (_p, { input }, ctx) => {\n  const r = requireRider(ctx);\n  const { name, phone, email, photo } = input;\n\n  if (typeof name === \"string\") r.name = name.trim().slice(0, 80);\n  if (typeof phone === \"string\") r.phone = phone.trim().slice(0, 32);\n  if (typeof photo === \"string\") r.photo = photo;\n\n  if (typeof email === \"string\") {\n    const trimmed = email.trim().toLowerCase();\n    if (trimmed && !/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(trimmed)) {\n      throw new GraphQLError(\"Некорректный email\", {\n        extensions: { code: \"BAD_USER_INPUT\" },\n      });\n    }\n    if (trimmed) {\n      const exists = await Rider.findOne({\n        email: trimmed,\n        _id: { $ne: r._id },\n      });\n      if (exists) {\n        throw new GraphQLError(\"Этот email уже используется\", {\n          extensions: { code: \"BAD_USER_INPUT\" },\n        });\n      }"},{"id":"rider_changeriderpassword","label":"changeRiderPassword()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L395-L415","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L395"}],"snippet":"changeRiderPassword = async (_p, { input }, ctx) => {\n  const r = requireRider(ctx);\n  const { oldPassword, newPassword } = input;\n\n  if (typeof newPassword !== \"string\" || newPassword.length < 6) {\n    throw new GraphQLError(\"Новый пароль должен быть не короче 6 символов\", {\n      extensions: { code: \"BAD_USER_INPUT\" },\n    });\n  }\n\n  const ok = await bcrypt.compare(oldPassword ?? \"\", r.passwordHash);\n  if (!ok) {\n    throw new GraphQLError(\"Текущий пароль указан неверно\", {\n      extensions: { code: \"BAD_USER_INPUT\" },\n    });\n  }\n\n  r.passwordHash = await bcrypt.hash(newPassword, 10);\n  await r.save();\n  return true;\n}"},{"id":"rider_rider","label":"rider()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L424-L457","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L424"}],"snippet":"rider = async (_p, { id }, ctx) => {\n  if (!ctx.user && !ctx.rider && !ctx.owner) {\n    throw new GraphQLError(\"Not authenticated\", {\n      extensions: { code: \"UNAUTHENTICATED\" },\n    });\n  }\n\n  // 1) Сам курьер или админ — видят всё\n  if (ctx.rider && ctx.rider._id.toString() === id) return Rider.findById(id);\n  if (ctx.owner) return Rider.findById(id);\n\n  // 2) User — только если этот курьер назначен на его активный заказ\n  if (ctx.user) {\n    const myActiveOrder = await Order.findOne({\n      userId: ctx.user._id,\n      riderId: id,\n      orderStatus: { $in: [\"ASSIGNED\", \"PICKED\", \"AWAITING_CONFIRMATION\"] },\n    });\n    if (myActiveOrder) {\n      return Rider.findById(id);\n    }\n    return publicRiderProfile(await Rider.findById(id));\n  }\n\n  // 3) Всем остальным — публичный профиль без координат"}],"edges":[{"source":"rider","target":"bcryptjs","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L1"}],"weight":1},{"source":"rider","target":"graphql","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L2"}],"weight":1},{"source":"rider","target":"order","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L3","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","source_location":"L3"}],"weight":1},{"source":"rider","target":"rider","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/rider.js","sou