{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"redis","label":"redis.js","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/redis.js","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/redis.js","source_location":"L1"}]},{"id":"redis_getredis","label":"getRedis()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/redis.js","source_location":"L32-L63","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/redis.js","source_location":"L32"}],"snippet":"export function getRedis() {\n  if (client) return client;\n  const url = REDIS_URL || `redis://${REDIS_HOST}:${REDIS_PORT}`;\n  client = new IORedis(url, {\n    password: REDIS_PASSWORD,\n    // ⭐ Retry strategy: экспоненциальный backoff\n    retryStrategy(times) {\n      return Math.min(times * 200, 5000);\n    },\n    // ⭐ Lazy connect — не блокируем startup, если Redis недоступен\n    lazyConnect: true,\n    maxRetriesPerRequest: 2,\n    enableOfflineQueue: false, // ⭐ не накапливать команды при отключении\n  });\n\n  client.on(\"connect\", () => {\n    connected = true;\n    debugLog(\"Redis\", \"connected\", {\n      host: REDIS_HOST,\n      port: REDIS_PORT,\n    });\n  });\n  client.on(\"error\", (err) => {\n    connected = false;\n    debugWarn(\"Redis\", \"error (graceful degradation to Mongo)\", err.message);"},{"id":"redis_isredisready","label":"isRedisReady()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/redis.js","source_location":"L65-L67","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/redis.js","source_location":"L65"}],"snippet":"export function isRedisReady() {\n  return connected;\n}"},{"id":"redis_tryredis","label":"tryRedis()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/redis.js","source_location":"L76-L94","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/redis.js","source_location":"L76"}],"snippet":"export async function tryRedis(op, fallback) {\n  try {\n    if (!connected) {\n      const c = getRedis();\n      try {\n        await c.connect();\n      } catch (e) {\n        // не взлетел — уходим в fallback\n        return fallback;\n      }\n      if (!isRedisReady()) return fallback;\n    }\n    // ⭐ К этому моменту client гарантированно инициализирован (или упали в fallback выше)\n    return await op(client);\n  } catch (e) {\n    debugWarn(\"Redis\", \"op failed, fallback\", e?.message || String(e));\n    return fallback;\n  }\n}"},{"id":"redis_initredis","label":"initRedis()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/redis.js","source_location":"L100-L107","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/redis.js","source_location":"L100"}],"snippet":"export async function initRedis() {\n  const c = getRedis();\n  try {\n    await c.connect();\n  } catch (e) {\n    debugWarn(\"Redis\", \"init failed (continuing without cache)\", e?.message);\n  }\n}"},{"id":"redis_checkratelimit","label":"checkRateLimit()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/redis.js","source_location":"L117-L138","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/redis.js","source_location":"L117"}],"snippet":"export async function checkRateLimit({ key, maxRequests, windowSeconds }) {\n  const fallback = { allowed: true, remaining: maxRequests, resetInSec: 0 };\n  if (!(await isRedisReady())) return fallback;\n\n  return await tryRedis(async (r) => {\n    const fullKey = `rl:${key}`;\n    // INCR + EXPIRE (атомарно через pipeline)\n    const pipeline = r.multi();\n    pipeline.incr(fullKey);\n    pipeline.expire(fullKey, windowSeconds, \"NX\"); // только если ключ новый\n    const results = await pipeline.exec();\n\n    const count = results?.[0]?.[1] ?? 0;\n    const ttl = await r.ttl(fullKey);\n\n    return {\n      allowed: count <= maxRequests,\n      remaining: Math.max(0, maxRequests - count),\n      resetInSec: Math.max(0, ttl),\n    };\n  }, fallback);\n}"}],"edges":[{"source":"redis","target":"ioredis","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/redis.js","source_location":"L20","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/redis.js","source_location":"L20"}],"weight":1},{"source":"redis","target":"debug_log","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/redis.js","source_location":"L21","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/redis.js","source_location":"L21"}],"weight":1},{"source":"redis","target":"redis_getredis","relation":"contains","confidence":"EXTR