{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"rider_location_flush_job","label":"rider-location-flush.job.js","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/jobs/rider-location-flush.job.js","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/jobs/rider-location-flush.job.js","source_location":"L1"}]},{"id":"rider_location_flush_job_runflush","label":"runFlush()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/jobs/rider-location-flush.job.js","source_location":"L31-L83","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/jobs/rider-location-flush.job.js","source_location":"L31"}],"snippet":"async function runFlush() {\n  const riderIds = await getAllRiderIdsInRedis();\n  if (riderIds.length === 0) {\n    debugLog(JOB_NAME, \"no riders in redis, skip\");\n    return;\n  }\n\n  const startedAt = Date.now();\n  const ops = [];\n\n  for (const riderId of riderIds) {\n    const loc = await getRiderLocationFromRedis(riderId);\n    if (!loc) {\n      // Данные протухли (TTL истёк между чтениями) — просто убираем из индекса\n      await removeRiderFromRedis(riderId);\n      continue;\n    }\n\n    ops.push({\n      updateOne: {\n        filter: { _id: riderId },\n        update: {\n          $set: {\n            location: { type: \"Point\", coordinates: [loc.lng, loc.lat] },\n            lastLocationAt: new Date(loc.updatedAt),"},{"id":"rider_location_flush_job_startriderlocationflushjob","label":"startRiderLocationFlushJob()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/jobs/rider-location-flush.job.js","source_location":"L92-L113","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/jobs/rider-location-flush.job.js","source_location":"L92"}],"snippet":"export function startRiderLocationFlushJob() {\n  if (task) {\n    debugWarn(JOB_NAME, \"already started\");\n    return;\n  }\n  if (process.env.DISABLE_CRON === \"1\") {\n    debugLog(JOB_NAME, \"disabled via env\");\n    return;\n  }\n\n  task = cron.schedule(\n    CRON_EXPR,\n    () => {\n      runFlush().catch((e) =>\n        debugError(JOB_NAME, \"uncaught error\", e?.message),\n      );\n    },\n    { scheduled: true, timezone: \"Asia/Dushanbe\" },\n  );\n\n  debugLog(JOB_NAME, \"started\", { expr: CRON_EXPR });\n}"},{"id":"rider_location_flush_job_stopriderlocationflushjob","label":"stopRiderLocationFlushJob()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/jobs/rider-location-flush.job.js","source_location":"L118-L124","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/jobs/rider-location-flush.job.js","source_location":"L118"}],"snippet":"export function stopRiderLocationFlushJob() {\n  if (task) {\n    task.stop();\n    task = null;\n    debugLog(JOB_NAME, \"stopped\");\n  }\n}"}],"edges":[{"source":"rider_location_flush_job","target":"node_cron","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/jobs/rider-location-flush.job.js","source_location":"L15","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/jobs/rider-location-flush.job.js","source_location":"L15"}],"weight":1},{"source":"rider_location_flush_job