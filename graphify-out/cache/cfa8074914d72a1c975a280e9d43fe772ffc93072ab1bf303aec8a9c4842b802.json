{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"mapconfig","label":"mapConfig.ts","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/mapConfig.ts","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/mapConfig.ts","source_location":"L1"}]},{"id":"mapconfig_isvalidcoord","label":"isValidCoord()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/mapConfig.ts","source_location":"L34-L43","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/mapConfig.ts","source_location":"L34"}],"snippet":"export function isValidCoord(v: any): v is [number, number] {\n  return (\n    Array.isArray(v) &&\n    v.length >= 2 &&\n    typeof v[0] === \"number\" &&\n    typeof v[1] === \"number\" &&\n    Number.isFinite(v[0]) &&\n    Number.isFinite(v[1])\n  );\n}"},{"id":"mapconfig_getlnglat","label":"getLngLat()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/mapConfig.ts","source_location":"L45-L48","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/mapConfig.ts","source_location":"L45"}],"snippet":"export function getLngLat(geo: any): [number, number] | null {\n  if (!isValidCoord(geo?.coordinates)) return null;\n  return [geo.coordinates[0], geo.coordinates[1]];\n}"},{"id":"mapconfig_getlatlng","label":"getLatLng()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/mapConfig.ts","source_location":"L50-L53","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/mapConfig.ts","source_location":"L50"}],"snippet":"export function getLatLng(geo: any): [number, number] | null {\n  if (!geo || !isValidCoord(geo.coordinates)) return null;\n  return [geo.coordinates[1], geo.coordinates[0]];\n}"},{"id":"mapconfig_formatdistance","label":"formatDistance()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/mapConfig.ts","source_location":"L55-L58","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/mapConfig.ts","source_location":"L55"}],"snippet":"export function formatDistance(km: number): string {\n  if (km < 1) return `${Math.round(km * 1000)} м`;\n  return `${km < 10 ? km.toFixed(1) : Math.round(km)} км`;\n}"},{"id":"mapconfig_haversinekm","label":"haversineKm()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/mapConfig.ts","source_location":"L60-L75","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/components/mapConfig.ts","source_location":"L60"}],"snippet":"export function haversineKm(\n  lat1: number,\n  lng1: number,\n  lat2: number,\n  lng2: number,\n): number {\n  const R = 6371;\n  const dLat = ((lat2 - lat1) * Math.PI) / 180;\n  const dLng = ((lng2 - lng1) * Math.PI) / 180;\n  const a =\n    Math.sin(dLat / 2) ** 2 +\n    Math.cos((lat1 * Math.PI) / 180) *\n      Math.cos((lat2 * Math.PI) / 180) *\n      Math.sin(dLng / 2) ** 2;\n  return 2 * R * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));\n}"}],"edges":[{"source":"mapconfig","target":"react_native","