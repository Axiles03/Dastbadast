{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"login","label":"login.tsx","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/login.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/login.tsx","source_location":"L1"}]},{"id":"login_login","label":"Login()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/login.tsx","source_location":"L36-L423","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/login.tsx","source_location":"L36"}],"snippet":"export default function Login() {\n  const [username, setUsername] = useState(\"courier1\");\n  const [password, setPassword] = useState(\"rider123\");\n  const [doLogin, { loading }] = useMutation(RIDER_LOGIN);\n  const { setAuth } = useAuth();\n  const router = useRouter();\n\n  // Конфиг API + кнопка \"Изменить\"\n  const [config, setConfig] = useState<ApiConfig | null>(null);\n  const [showUrlModal, setShowUrlModal] = useState(false);\n  const [testResult, setTestResult] = useState<{\n    ok: boolean;\n    msg: string;\n    ms?: number;\n  } | null>(null);\n  const [testing, setTesting] = useState(false);\n\n  // Поле ввода URL в модалке\n  const [urlInput, setUrlInput] = useState(\"\");\n  const [urlError, setUrlError] = useState<string | null>(null);\n  const [savingUrl, setSavingUrl] = useState(false);\n\n  useEffect(() => {\n    initApiConfig().then(setConfig);\n  }, []);","node_kind":"component"},{"id":"login_login_submit","label":"submit()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/login.tsx","source_location":"L62-L83","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/login.tsx","source_location":"L62"}],"snippet":"submit = async () => {\n    try {\n      const res = await doLogin({\n        variables: { input: { username, password } },\n      });\n      const data = res.data as any;\n      const { token, rider } = data.riderLogin;\n      if (!token || !rider) throw new Error(\"Неверный ответ сервера\");\n      await setAuth(token, rider);\n      router.replace(\"/orders\");\n    } catch (e: any) {\n      let msg = e?.message ?? \"Не удалось войти\";\n      if (/NoRouteToHost|Network request failed|fetch failed/i.test(msg)) {\n        msg = `Не удалось подключиться к API.\\n\\nURL: ${GRAPHQL_HTTP}\\n\\nЧто проверить:\\n• API запущен на Mac (порт 8001)\\n• Mac и телефон в одной Wi-Fi\\n• Если используется Expo Go — нажмите на URL ниже и введите IP Mac вручную`;\n      } else if (/timeout/i.test(msg)) {\n        msg = \"Таймаут соединения. Проверьте URL и сеть.\";\n      } else if (/invalid|graphql/i.test(msg)) {\n        // оставляем как есть\n      }\n      Alert.alert(\"Ошибка входа\", msg);\n    }\n  }"},{"id":"login_login_openurlmodal","label":"openUrlModal()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/login.tsx","source_location":"L85-L90","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/login.tsx","source_location":"L85"}],"snippet":"openUrlModal = () => {\n    setUrlInput(config?.http || \"\");\n    setUrlError(null);\n    setTestResult(null);\n    setShowUrlModal(true);\n  }"},{"id":"login_login_handletest","label":"handleTest()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/login.tsx","source_location":"L92-L114","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/login.tsx","source_location":"L92"}],"snippet":"handleTest = async () => {\n    if (!urlInput.trim()) {\n      setUrlError(\"Введите URL\");\n      return;\n    }\n    if (!/^https?:\\/\\//i.test(urlInput.trim())) {\n      setUrlError(\"Должен начинаться с http:// или https://\");\n      return;\n    }\n    setTesting(true);\n    setTestResult(null);\n    const res = await testConnection(urlInput.trim());\n    setTesting(false);\n    if (res.ok) {\n      setTestResult({\n        ok: true,\n        msg: `OK · ${res.status ?? 200}`,\n        ms: res.ms,\n      });\n    } else {\n      setTestResult({ ok: false, msg: res.error ?? \"Ошибка\" });\n    }\n  }"},{"id":"login_login_handlesaveurl","label":"handleSaveUrl()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/login.tsx","source_location":"L116-L141","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/login.tsx","source_location":"L116"}],"snippet":"handleSaveUrl = async () => {\n    if (!urlInput.trim()) {\n      setUrlError(\"Введите URL\");\n      return;\n    }\n    if (!/^https?:\\/\\//i.test(urlInput.trim())) {\n      setUrlError(\"Должен начинаться с http:// или https://\");\n      return;\n    }\n    setSavingUrl(true);\n    try {\n      await setApiUrlOverride(urlInput.trim());\n      resetApolloClient();\n      const fresh = await initApiConfig();\n      setConfig(fresh);\n      setShowUrlModal(false);\n      Alert.alert(\n        \"Готово\",\n        \"URL сохранён. Apollo-клиент пересоздан — попробуйте войти.\",\n      );\n    } catch (e: any) {\n      setUrlError(e?.message ?? \"Не удалось сохранить\");\n    } finally {\n      setSavingUrl(false);\n    }"},{"id":"login_login_handlereseturl","label":"handleResetUrl()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/login.tsx","source_location":"L143-L156","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/login.tsx","source_location":"L143"}],"snippet":"handleResetUrl = async () => {\n    setSavingUrl(true);\n    try {\n      await clearApiUrlOverride();\n      resetApolloClient();\n      const fresh = await initApiConfig();\n      setConfig(fresh);\n      setUrlInput(fresh.http);\n      setUrlError(null);\n      setTestResult(null);\n    } finally {\n      setSavingUrl(false);\n    }\n  }"}],"edges":[{"source":"login","target":"react","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/login.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/login.tsx","source_location":"L1"}],"weight":1},{"source":"login","target":"react_native","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/login.tsx","source_location":"L2","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/login.tsx","source_location":"L2"}],"weight":1},{"source":"login","target":"queries","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-rider/app/(app)/login.tsx","source_location":"L16