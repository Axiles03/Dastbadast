{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"page","label":"page.tsx","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dispatch/page.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dispatch/page.tsx","source_location":"L1"}]},{"id":"page_timeago","label":"timeAgo()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dispatch/page.tsx","source_location":"L77-L92","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dispatch/page.tsx","source_location":"L77"}],"snippet":"function timeAgo(dateString: string | Date | null | undefined): string {\n  if (!dateString) return \"—\";\n  const d = new Date(dateString);\n  if (isNaN(d.getTime())) return \"—\";\n  const ms = Date.now() - d.getTime();\n  if (ms < 0) return \"только что\";\n  const sec = Math.floor(ms / 1000);\n  if (sec < 60) return \"только что\";\n  const min = Math.floor(sec / 60);\n  if (min < 60) return `${min} мин назад`;\n  const hr = Math.floor(min / 60);\n  if (hr < 24) return `${hr} ч назад`;\n  const days = Math.floor(hr / 24);\n  if (days < 30) return `${days} дн назад`;\n  return d.toLocaleDateString(\"ru\", { day: \"numeric\", month: \"short\" });\n}"},{"id":"page_cancelreasonlabel","label":"cancelReasonLabel()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dispatch/page.tsx","source_location":"L94-L99","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dispatch/page.tsx","source_location":"L94"}],"snippet":"function cancelReasonLabel(reason: string | null | undefined): string {\n  if (!reason) return \"Причина не указана\";\n  if (CANCEL_REASON_LABEL[reason]) return CANCEL_REASON_LABEL[reason];\n  if (reason.length > 60) return reason.substring(0, 60) + \"…\";\n  return reason;\n}"},{"id":"page_getcancelicon","label":"getCancelIcon()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dispatch/page.tsx","source_location":"L101-L108","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dispatch/page.tsx","source_location":"L101"}],"snippet":"function getCancelIcon(reason: string | null | undefined): string {\n  if (reason === \"AUTO_EXPIRED\") return \"⏰\";\n  if (reason?.toLowerCase().includes(\"нет продукт\")) return \"🚫\";\n  if (reason?.toLowerCase().includes(\"ресторан\")) return \"❌\";\n  if (reason?.toLowerCase().includes(\"курьер\")) return \"🛵\";\n  if (reason?.toLowerCase().includes(\"клиент\")) return \"👤\";\n  return \"✕\";\n}"},{"id":"page_dispatchpage","label":"DispatchPage()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dispatch/page.tsx","source_location":"L110-L116","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dispatch/page.tsx","source_location":"L110"}],"snippet":"export default function DispatchPage() {\n  return (\n    <RoleGate allowedRoles={NAV_ACCESS.dispatch}>\n      <DispatchInner />\n    </RoleGate>\n  );\n}","node_kind":"component","framework":"nextjs","framework_role":"next_client_component","runtime_boundary":"client"},{"id":"page_dispatchinner","label":"DispatchInner()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-a