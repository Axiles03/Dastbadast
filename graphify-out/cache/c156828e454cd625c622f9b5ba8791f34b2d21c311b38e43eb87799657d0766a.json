{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"order_search","label":"order-search.js","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L1"}]},{"id":"order_search_dispatchcouriersearch","label":"dispatchCourierSearch()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L43-L176","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L43"}],"snippet":"export async function dispatchCourierSearch({\n  orderId,\n  escalation = false,\n  excludeIds = [],\n}) {\n  if (!orderId) return [];\n\n  // 1) Ранние выходы: заказ нерелевантен\n  const order = await Order.findById(orderId).lean();\n  if (!order) return [];\n  if (order.riderId) return [];\n  if (![\"PENDING\", \"ACCEPTED\"].includes(order.orderStatus)) return [];\n\n  // 2) Лимит волн (защита от бесконечного поиска)\n  const tsField = escalation\n    ? \"statusTimestamps.courierSearchTimestamps.escalationPushedAt\"\n    : \"statusTimestamps.courierSearchTimestamps.initialPushedAt\";\n  if (!escalation) {\n    const currentWave = await getCurrentWaveCount(orderId);\n    if (currentWave >= COURIER_SEARCH_RULES.MAX_PUSH_WAVES) {\n      debugLog(JOB, \"max waves reached, manual assign only\", { orderId });\n      return [];\n    }\n  }"},{"id":"order_search_startcouriersearchescalation1","label":"startCourierSearchEscalation1()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L182-L213","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L182"}],"snippet":"export async function startCourierSearchEscalation1(orderId) {\n  // 1. Сразу отправляем первую волну\n  const firstWave = await dispatchCourierSearch({\n    orderId,\n    escalation: false,\n  });\n  if (firstWave.length === 0) {\n    debugLog(JOB, \"first wave empty, skip escalation\", { orderId });\n    return { firstWave: [], escalation: [] };\n  }\n\n  // 2. Планируем эскалацию через 90 сек (если курьер не был назначен)\n  setTimeout(async () => {\n    try {\n      const order = await Order.findById(orderId).lean();\n      if (!order) return;\n      if (order.riderId) return; // уже взят — эскалация не нужна\n      if (![\"PENDING\", \"ACCEPTED\"].includes(order.orderStatus)) return;\n\n      const secondWave = await dispatchCourierSearch({\n        orderId,\n        escalation: true,\n        // excludeIds НЕ передаём — берём их из Redis внутри\n      });\n      debugLog(JOB, \"escalation done\", { orderId, secondWave });"},{"id":"order_search_isrestauranthot","label":"isRestaurantHot()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L227-L236","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L227"}],"snippet":"export async function isRestaurantHot(restaurantId) {\n  if (!restaurantId) return false;\n  const oneHourAgo = new Date(Date.now() - 60 * 60 * 1000);\n  const count = await Order.countDocuments({\n    restaurantId,\n    createdAt: { $gte: oneHourAgo },\n    orderStatus: { $nin: [\"CANCELLED\"] },\n  });\n  return count >= COURIER_SEARCH_RULES.HOT_ZONE_THRESHOLD;\n}"},{"id":"order_search_findcandidatesgeonear","label":"findCandidatesGeoNear()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L256-L299","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L256"}],"snippet":"async function findCandidatesGeoNear(lat, lng, radiusKm, limit) {\n  // $geoNear требует, чтобы он был ПЕРВЫМ stage в aggregation pipeline.\n  // Также требует 2dsphere-индекс.\n  const pipeline = [\n    {\n      $geoNear: {\n        near: { type: \"Point\", coordinates: [lng, lat] },\n        distanceField: \"distanceM\", // результат в метрах\n        maxDistance: radiusKm * 1000,\n        spherical: true,\n        query: { isActive: true }, // ⭐ только активные (отписавшиеся — нет)\n      },\n    },\n    { $limit: limit * 2 }, // ⭐ берём 2× лимит на случай, если часть отвалится на фильтрах\n    {\n      $project: {\n        username: 1,\n        name: 1,\n        available: 1,\n        isActive: 1,\n        zoneId: 1,\n        location: 1,\n        lastLocationAt: 1,\n        bearing: 1,\n        distanceM: 1,"},{"id":"order_search_findcandidatesinmemory","label":"findCandidatesInMemory()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L305-L317","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L305"}],"snippet":"async function findCandidatesInMemory(lat, lng, radiusKm, limit) {\n  const riders = await Rider.find({ isActive: true })\n    .select(\n      \"username name available isActive zoneId location lastLocationAt bearing\",\n    )\n    .limit(500) // safety\n    .lean();\n  const ranked = rankRidersByDistance(riders, lat, lng);\n  return ranked\n    .filter((x) => x.distance <= radiusKm)\n    .slice(0, limit)\n    .map((x) => ({ rider: x.rider, distance: x.distance }));\n}"},{"id":"order_search_getoverworkedriders","label":"getOverworkedRiders()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L327-L360","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L327"}],"snippet":"async function getOverworkedRiders() {\n  const overworked = new Set();\n  const max = COURIER_SEARCH_RULES.MAX_ACTIVE_ORDERS_PER_RIDER;\n\n  // Активные статусы = курьер всё ещё доставляет\n  const ACTIVE_STATUSES = [\n    \"ASSIGNED\",\n    \"PICKED\",\n    \"EN_ROUTE_TO_DROP_OFF\",\n    \"ARRIVED_AT_DROP_OFF\",\n    \"AWAITING_CONFIRMATION\",\n  ];\n\n  const pipeline = [\n    {\n      $match: { orderStatus: { $in: ACTIVE_STATUSES }, riderId: { $ne: null } },\n    },\n    {\n      $group: {\n        _id: \"$riderId\",\n        count: { $sum: 1 },\n      },\n    },\n    { $match: { count: { $gte: max } } },\n  ];"},{"id":"order_search_getcurrentwavecount","label":"getCurrentWaveCount()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L366-L374","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L366"}],"snippet":"async function getCurrentWaveCount(orderId) {\n  const order = await Order.findById(orderId)\n    .select(\"statusTimestamps.courierSearchTimestamps\")\n    .lean();\n  if (!order) return 0;\n  const cs = order.statusTimestamps?.courierSearchTimestamps;\n  if (!cs) return 0;\n  return (cs.initialPushedAt ? 1 : 0) + (cs.escalationPushedAt ? 1 : 0);\n}"},{"id":"order_search_addtoexcludelist","label":"addToExcludeList()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L384-L398","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L384"}],"snippet":"async function addToExcludeList(orderId, riderIds) {\n  if (!riderIds?.length) return;\n  if (!(await isRedisReady())) return;\n  const key = excludeKey(orderId);\n  tryRedis(async (r) => {\n    // Используем SADD + EXPIRE (если ключ новый — ставим TTL)\n    const pipeline = r.multi();\n    pipeline.sadd(key, ...riderIds);\n    pipeline.expire(\n      key,\n      Math.floor(COURIER_SEARCH_RULES.RIDER_EXCLUDE_TTL_MS / 1000),\n    );\n    await pipeline.exec();\n  }, false);\n}"},{"id":"order_search_getexcludelist","label":"getExcludeList()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L403-L411","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L403"}],"snippet":"async function getExcludeList(orderId) {\n  const set = new Set();\n  if (!(await isRedisReady())) return set;\n  await tryRedis(async (r) => {\n    const ids = await r.smembers(excludeKey(orderId));\n    for (const id of ids) set.add(String(id));\n  }, false);\n  return set;\n}"},{"id":"order_search_clearcourierexcludelist","label":"clearCourierExcludeList()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L419-L425","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L419"}],"snippet":"export async function clearCourierExcludeList(orderId) {\n  if (!orderId) return;\n  if (!(await isRedisReady())) return;\n  await tryRedis(async (r) => {\n    await r.del(excludeKey(orderId));\n  }, false);\n}"},{"id":"order_search_schedulejustintimedispatch","label":"scheduleJustInTimeDispatch()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L431-L450","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/order-search.js","source_location":"L431"}],"snippet":"export function scheduleJustInTimeDispatch(orderId, prepTimeMinutes) {\n  const prepMin = Number(prepTimeMinutes) || 0;\n  const delayMin = Math.max(0, prepMin - COURIER_LEAD_TIME_MIN);\n  const delayMs = delayMin * 60_000;\n\n  setTimeout(async () => {\n    try {\n      const order = await Order.findById(orderId).lean();\n      if (!order) return;\n      if (order.riderId) return;\n      if (![\"PENDING\", \"ACCEPTED\"].includes(order.orderStatus)) return;\n      await startCourierSearchEscalation1(orderId);\n    } catch (e) {\n      debugError(JOB, \"just-in-time dispatch failed\", {\n        orderId,\n        message: e.message,\n      });\n    }\n  }, delayMs);\n}"}],"edges":[{"source":"order_search","target":"order","relation":"imports_from","confidence":"EXTRACTED","source_file":"