ltivendor-web/app/(main)/address/page.tsx","source_location":"L47-L394","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-web/app/(main)/address/page.tsx","source_location":"L47"}],"snippet":"function AddressInner() {\n  const { user } = useAuth();\n  const [notice, setNotice] = useState<{\n    text: string;\n    type: \"success\" | \"error\";\n  } | null>(null);\n\n  useEffect(() => {\n    if (!notice) return;\n    const t = setTimeout(() => setNotice(null), 3000);\n    return () => clearTimeout(t);\n  }, [notice]);\n\n  const [selectAddress] = useMutation(SELECT_ADDRESS, {\n    refetchQueries: [{ query: GET_ADDRESSES }],\n    awaitRefetchQueries: true,\n    onError: (e) => setNotice({ text: e.message, type: \"error\" }),\n  });\n\n  const [deleteAddress] = useMutation(DELETE_ADDRESS, {\n    refetchQueries: [{ query: GET_ADDRESSES }],\n    awaitRefetchQueries: true,\n    onCompleted: () => setNotice({ text: \"Адрес удалён\", type: \"success\" }),\n    onError: (e) => setNotice({ text: e.message, type: \"error\" }),\n  });","node_kind":"component"},{"id":"page_addressinner_usemylocation","label":"useMyLocation()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-web/app/(main)/address/page.tsx","source_location":"L115-L137","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-web/app/(main)/address/page.tsx","source_location":"L115"}],"snippet":"useMyLocation = () => {\n    if (!navigator.geolocation) {\n      alert(\"Геолокация недоступна в браузере\");\n      return;\n    }\n    setGeoLoading(true);\n    navigator.geolocation.getCurrentPosition(\n      async (pos) => {\n        const lat = pos.coords.latitude;\n        const lng = pos.coords.longitude;\n        const inZone = !zonePolygon?.length\n          ? true\n          : isInZone(lng, lat, zonePolygon);\n        await applyCoords(lat, lng, inZone);\n        setGeoLoading(false);\n      },\n      () => {\n        setGeoLoading(false);\n        alert(\"Не удалось получить местоположение\");\n      },\n      { enableHighAccuracy: true, timeout: 15000 },\n    );\n  }"},{"id":"page_addressinner_submit","label":"submit()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-web/app/(main)/address/page.tsx","source_location":"L139-L164","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-web/app/(main)/address/page.tsx","source_location":"L139"}],"snippet":"submit = async (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!pointInZone) {\n      alert(\n        \"Точка вне зоны доставки. Переместите маркер внутрь оранжевой области.\",\n      );\n      return;\n    }\n    try {\n      await createAddress({\n        variables: {\n          input: {\n            label: form.label,\n            address: form.address,\n            city: form.city,\n            location: { type: \"Point\", coordinates: [form.lng, form.lat] },\n          },\n        },\n      });\n      setForm({ ...form, address: \"\" });\n      setShowForm(false);\n      refetch();\n    } catch (err) {\n      // shown below\n    }"},{"id":"page_isinzone","label":"isInZone()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-web/app/(main)/address/page.tsx","source_location":"L396-L408","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-web/app/(main)/address/page.tsx","source_location":"L396"}],"snippet":"function isInZone(lng: number, lat: number, polygon: number[][]): boolean {\n  if (!polygon?.length) return true;\n  const [x, y] = [lng, lat];\n  let inside = false;\n  for (let i = 0, j = polygon.length - 1; i < polygon.length; j = i++) {\n    const [xi, yi] = polygon[i];\n    const [xj, yj] = polygon[j];\n    const intersect =\n      yi > y !== yj > y && x < ((xj - xi) * (y - yi)) / (yj - yi) + xi;\n    if (intersect) inside = !inside;\n  }\n  return inside;\n}"},{"id":"users_motionup_desktop_dastbadast_main_dastbadast_multivendor_web_nextjs_route_address","label":"/address","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-web/app","source_location":"L1","layer":"base","node_kind":"route","framework":"nextjs","framework_role":"next_route","route_path":"/address"},{"id":"users_motionup_desktop_dastbadast_main_dastbadast_multivendor_web_nextjs_page_address","label":"page /address","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-web/app/(main)/address/page.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-web/app/(main)/address/page.tsx","source_location":"L1"}],"node_kind":"component","framework":"nextjs","framework_role":"next_page","route_path":"/address","runtime_boundary":"client"},{"id":"users_motionup_desktop_dastbadast_main_dastbadast_multivendor_web_nextjs_layout","label":"layout /","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-web/app/layout.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-web/app/layout.tsx","source_location":"L1"}],"node_kind":"component","framework":"nextjs","framework_role":"next_layout","route_path":"/"}],"edges":[{"source":"page","target":"react","relation":"imports_from","confidence":"EXTRA