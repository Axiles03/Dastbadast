{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"mapview","label":"MapView.tsx","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/map/MapView.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/map/MapView.tsx","source_location":"L1"}]},{"id":"mapview_makeroutekey","label":"makeRouteKey()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/map/MapView.tsx","source_location":"L68-L71","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/map/MapView.tsx","source_location":"L68"}],"snippet":"function makeRouteKey(from: RoutePoint, to: RoutePoint): string {\n  const r = (n: number) => Math.round(n * 1e4) / 1e4;\n  return `${r(from[0])},${r(from[1])}__${r(to[0])},${r(to[1])}`;\n}"},{"id":"mapview_makeroutekey_r","label":"r()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/map/MapView.tsx","source_location":"L69","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/map/MapView.tsx","source_location":"L69"}],"snippet":"r = (n: number) => Math.round(n * 1e4) / 1e4"},{"id":"mapview_fetchosrmroute","label":"fetchOSRMRoute()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/map/MapView.tsx","source_location":"L73-L101","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/map/MapView.tsx","source_location":"L73"}],"snippet":"async function fetchOSRMRoute(\n  from: RoutePoint,\n  to: RoutePoint,\n): Promise<RoutePoint[] | null> {\n  const key = makeRouteKey(from, to);\n  const cached = OSRM_CACHE.get(key);\n  if (cached && Date.now() - cached.at < OSRM_CACHE_TTL_MS) {\n    return cached.coords;\n  }\n\n  const url = `https://router.project-osrm.org/route/v1/driving/${from[0]},${from[1]};${to[0]},${to[1]}?overview=full&geometries=geojson`;\n\n  try {\n    const controller = new AbortController();\n    const timeoutId = setTimeout(() => controller.abort(), OSRM_TIMEOUT_MS);\n    const res = await fetch(url, { signal: controller.signal });\n    clearTimeout(timeoutId);\n    if (!res.ok) return null;\n    const data = await res.json();\n    const route = data?.routes?.[0];\n    const coords: [number, number][] | undefined = route?.geometry?.coordinates;\n    if (!Array.isArray(coords) || coords.length < 2) return null;\n    const result: RoutePoint[] = coords.map(([lng, lat]) => [lng, lat]);\n    OSRM_CACHE.set(key, { coords: result, at: Date.now() });\n    return result;"},{"id":"mapview_getroute","label":"getRoute()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/map/MapView.tsx","source_location":"L103-L109","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/map/MapView.tsx","source_location":"L103"}],"snippet":"async function getRoute(\n  from: RoutePoint,\n  to: RoutePoint,\n): Promise<RoutePoint[]> {\n  const fetched = await fetchOSRMRoute(from, to);\n  return fetched || [from, to]; // fallback на прямую если OSRM недоступен\n}"},{"id":"mapview_pickcolor","label":"pickColor()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/map/MapView.tsx","source_location":"L113-L128","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/map/MapView.tsx","source_location":"L113"}],"snippet":"function pickColor(orderStatus: string): string {\n  switch (orderStatus) {\n    case \"PENDING\":\n      return \"#F5A623\";\n    case \"ACCEPTED\":\n      return \"#6E5BFF\";\n    case \"ASSIGNED\":\n      return \"#2D9CDB\";\n    case \"PICKED\":\n      return \"#16A34A\";\n    case \"AWAITING_CONFIRMATION\":\n      return \"#F26A4A\";\n    default:\n      return \"#9A9388\";\n  }\n}"},{"id":"mapview_makeriderel","label":"makeRiderEl()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/map/MapView.tsx","source_location":"L130-L148","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/map/MapView.tsx","source_location":"L130"}],"snippet":"function makeRiderEl(rider: AnyRider, isSelected: boolean): HTMLDivElement {\n  const el = document.createElement(\"div\");\n  el.style.position = \"relative\";\n  el.style.width = \"44px\";\n  el.style.height = \"44px\";\n  el.style.cursor = \"pointer\";\n  el.style.transform = \"translate(-50%, -50%)\";\n\n  const isOffline = !rider.available || rider.isActive === false;\n  const bg = isOffline ? \"#9A9388\" : \"#16A34A\";\n\n  el.innerHTML = `\n    <div style=\"position:absolute;inset:0;background:${bg};transform:rotate(45deg);border-radius:8px;box-shadow:0 2px 8px rgba(0,0,0,0.25);border:3px solid white;${\n      isSelected ? \"outline:3px solid #F26A4A;outline-offset:2px;\" : \"\"\n    }\"></div>\n    <div style=\"position:absolute;inset:0;display:flex;align-items:center;justify-content:center;transform:rotate(-45deg);font-size:20px;\">🛵</div>\n  `;\n  return el;\n}"},{"id":"mapview_makeorderel","label":"makeOrderEl()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/map/MapView.tsx","source_location":"L150-L168","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/map/MapView.tsx","source_location":"L150"}],"snippet":"function makeOrderEl(order: AnyOrder, isSelected: boolean): HTMLDivElement {\n  const el = document.createElement(\"div\");\n  el.style.position = \"relative\";\n  el.style.width = \"32px\";\n  el.style.height = \"32px\";\n  el.style.cursor = \"pointer\";\n  el.style.transform = \"translate(-50%, -50%)\";\n\n  const color = pickColor(order.orderStatus);\n\n  el.innerHTML = `\n    <div style=\"position:absolute;inset:0;background:${color};border-radius:50%;border:3px solid white;box-shadow:0 2px 6px rgba(0,0,0,0.2);display:flex;align-items:center;justify-content:center;color:white;font-weight:800;font-size:14px;${\n      isSelected ? \"outline:3px solid #F26A4A;outline-offset:2px;\" : \"\"\n    }\">\n      ${order.orderStatus === \"PENDING\" ? \"?\" : \"\"}\n    </div>\n  `;\n  return el;\n}"},{"id":"mapview_makerestaurantel","label":"makeRestaurantEl()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/map/MapView.tsx","source_location":"L170-L181","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/map/MapView.tsx","source_location":"L170"}],"snippet":"function makeRestaurantEl(): HTMLDivElement {\n  const el = document.createElement(\"div\");\n  el.style.position = \"relative\";\n  el.style.width = \"28px\";\n  el.style.height = \"28px\";\n  el.style.transform = \"translate(-50%, -50%)\";\n  el.style.cursor = \"default\";\n  el.innerHTML = `\n    <div style=\"position:absolute;inset:0;background:white;border-radius:50%;border:2px solid #6E5BFF;box-shadow: