{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"page","label":"page.tsx","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dashboard/page.tsx","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dashboard/page.tsx","source_location":"L1"}]},{"id":"page_dashboardpage","label":"DashboardPage()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dashboard/page.tsx","source_location":"L59-L82","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dashboard/page.tsx","source_location":"L59"}],"snippet":"export default function DashboardPage() {\n  const { owner, loading } = useAuth();\n  const router = useRouter();\n\n  useEffect(() => {\n    document.body.style.backgroundColor = \"#FAF7F2\";\n    return () => {\n      document.body.style.backgroundColor = \"\";\n    };\n  }, []);\n\n  useEffect(() => {\n    if (typeof window === \"undefined\") return;\n    if (!loading && !owner) router.push(\"/login\");\n  }, [owner, loading, router]);\n\n  if (!owner) return null;\n\n  return (\n    <div className=\"space-y-6\">\n      <DashboardInner />\n    </div>\n  );\n}","node_kind":"component","framework":"nextjs","framework_role":"next_client_component","runtime_boundary":"client"},{"id":"page_dashboardinner","label":"DashboardInner()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dashboard/page.tsx","source_location":"L84-L419","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dashboard/page.tsx","source_location":"L84"}],"snippet":"function DashboardInner() {\n  const { owner } = useAuth();\n  const { data, loading, error, refetch, subscribeToMore } = useQuery(\n    ADMIN_DASHBOARD,\n    {\n      fetchPolicy: \"cache-and-network\",\n      pollInterval: 15_000,\n    },\n  );\n\n  useEffect(() => {\n    if (!subscribeToMore) return;\n    const unsubscribe = subscribeToMore({\n      document: SUB_ZONE_ORDERS,\n      variables: { zoneId: null },\n      updateQuery: () => {\n        refetch();\n        return data ?? { adminDashboardMetrics: null };\n      },\n    });\n    return () => unsubscribe?.();\n  }, [subscribeToMore, refetch, data]);\n\n  // ⭐ NEW: 3 параллельных запроса для новых секций\n  const [forecastDays, setForecastDays] = useState<number>(7);","node_kind":"component"},{"id":"page_churncard","label":"ChurnCard()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dashboard/page.tsx","source_location":"L425-L522","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dashboard/page.tsx","source_location":"L425"}],"snippet":"function ChurnCard({\n  data,\n  period,\n  onPeriodChange,\n}: {\n  data: any;\n  period: number;\n  onPeriodChange: (p: number) => void;\n}) {\n  const pct = data?.churnRatePct ?? 0;\n  // ⭐ Цвет: зелёный (< 20%), жёлтый (20-40%), красный (> 40%)\n  const tone =\n    pct < 20\n      ? {\n          color: \"#16A34A\",\n          label: \"🟢 Отличный retention\",\n          bg: \"bg-soft-success-soft border-soft-success/30\",\n        }\n      : pct < 40\n        ? {\n            color: \"#F5A623\",\n            label: \"🟡 Нормальный уровень\",\n            bg: \"bg-soft-warning-soft border-soft-warning/30\",\n          }\n        : {","node_kind":"component"},{"id":"page_forecastcard","label":"ForecastCard()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dashboard/page.tsx","source_location":"L524-L648","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dashboard/page.tsx","source_location":"L524"}],"snippet":"function ForecastCard({\n  data,\n  days,\n  onDaysChange,\n}: {\n  data: any;\n  days: number;\n  onDaysChange: (d: number) => void;\n}) {\n  const totals = data?.totals;\n  const forecast = data?.forecast ?? [];\n  const history = data?.history ?? [];\n\n  // ⭐ Объединяем историю + прогноз для единой линии графика\n  const chartData = useMemo(() => {\n    const series: Array<{\n      date: string;\n      history?: number;\n      forecast?: number;\n    }> = [];\n    for (const h of history) {\n      series.push({ date: h.date.slice(5), history: h.revenue });\n    }\n    for (const f of forecast) {\n      series.push({ date: f.date.slice(5), forecast: f.predictedRevenue });","node_kind":"component"},{"id":"page_cohortheatmapcard","label":"CohortHeatmapCard()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dashboard/page.tsx","source_location":"L650-L738","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dashboard/page.tsx","source_location":"L650"}],"snippet":"function CohortHeatmapCard({ data }: { data: any }) {\n  const cohorts = data?.cohorts ?? [];\n  const maxMonths = data?.months ?? 3;\n\n  function colorForRetention(pct: number): string {\n    if (pct === 0) return \"bg-soft-surface-2 text-soft-text-muted\";\n    if (pct >= 70) return \"bg-emerald-700 text-white\";\n    if (pct >= 50) return \"bg-emerald-500 text-white\";\n    if (pct >= 35) return \"bg-emerald-300 text-emerald-900\";\n    if (pct >= 20) return \"bg-amber-300 text-amber-900\";\n    if (pct >= 10) return \"bg-orange-300 text-orange-900\";\n    if (pct > 0) return \"bg-red-200 text-red-900\";\n    return \"bg-soft-surface-2 text-soft-text-muted\";\n  }\n\n  return (\n    <section className=\"bg-soft-surface border border-soft-border rounded-3xl p-5 shadow-soft-sm overflow-x-auto\">\n      <div className=\"flex items-center justify-between mb-4\">\n        <h2 className=\"text-lg font-extrabold text-soft-text flex items-center gap-2\">\n          <Calendar className=\"w-4 h-4 text-soft-accent\" />\n          Retention по когортам (3 мес)\n        </h2>\n        <Link\n          href=\"/users/cohorts\"\n          className=\"text-xs font-extrabold text-soft-accent hover:underline flex items-center gap-0.5\"","node_kind":"component"},{"id":"page_cohortheatmapcard_colorforretention","label":"colorForRetention()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dashboard/page.tsx","source_location":"L654-L663","layer":"base","provenance":[{"capability_id":"builtin:extract:typescript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dashboard/page.tsx","source_location":"L654"}],"snippet":"function colorForRetention(pct: number): string {\n    if (pct === 0) return \"bg-soft-surface-2 text-soft-text-muted\";\n    if (pct >= 70) return \"bg-emerald-700 text-white\";\n    if (pct >= 50) return \"bg-emerald-500 text-white\";\n    if (pct >= 35) return \"bg-emerald-300 text-emerald-900\";\n    if (pct >= 20) return \"bg-amber-300 text-amber-900\";\n    if (pct >= 10) return \"bg-orange-300 text-orange-900\";\n    if (pct > 0) return \"bg-red-200 text-red-900\";\n    return \"bg-soft-surface-2 text-soft-text-muted\";\n  }"},{"id":"page_row","label":"Row()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-admin/app/dashboard/page.tsx","source_location":"L740-L755","layer":"