{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"health","label":"health.js","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/middleware/health.js","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/middleware/health.js","source_location":"L1"}]},{"id":"health_tracksubscription","label":"trackSubscription()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/middleware/health.js","source_location":"L17-L21","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/middleware/health.js","source_location":"L17"}],"snippet":"export function trackSubscription(action) {\n  // action = \"open\" | \"close\"\n  if (action === \"open\") activeSubscriptions++;\n  else if (action === \"close\" && activeSubscriptions > 0) activeSubscriptions--;\n}"},{"id":"health_getmongostatus","label":"getMongoStatus()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/middleware/health.js","source_location":"L23-L26","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/middleware/health.js","source_location":"L23"}],"snippet":"function getMongoStatus() {\n  // Mongoose states: 0=disconnected, 1=connected, 2=connecting, 3=disconnecting\n  return mongoose.connection.readyState === 1 ? \"up\" : \"down\";\n}"},{"id":"health_getredisstatus","label":"getRedisStatus()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/middleware/health.js","source_location":"L28-L30","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/middleware/health.js","source_location":"L28"}],"snippet":"function getRedisStatus() {\n  return isRedisReady() ? \"up\" : \"down\";\n}"},{"id":"health_healthlivehandler","label":"healthLiveHandler()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/middleware/health.js","source_location":"L32-L37","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/middleware/health.js","source_location":"L32"}],"snippet":"export function healthLiveHandler(req, res) {\n  res.status(200).json({\n    status: \"ok\",\n    uptimeSec: Math.floor((Date.now() - startedAt) / 1000),\n  });\n}"},{"id":"health_healthreadyhandler","label":"healthReadyHandler()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/middleware/health.js","source_location":"L39-L48","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/middleware/health.js","source_location":"L39"}],"snippet":"export async function healthReadyHandler(req, res) {\n  const mongo = getMongoStatus();\n  const redis = getRedisStatus();\n  const ready = mongo === \"up\"; // Redis — optional, Mongo критичен\n  res.status(ready ? 200 : 503).json({\n    status: ready ? \"ready\" : \"not_ready\",\n    mongo,\n    redis,\n  });\n}"},{"id":"health_healthmetricshandler","label":"healthMetricsHandler()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/middleware/health.js","source_location":"L50-L70","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/middleware/health.js","source_location":"L50"}],"snippet":"export function healthMetricsHandler(req, res) {\n  const mem = process.memoryUsage();\n  const cache = getCacheStats();\n  res.json({\n    pid: process.pid,\n    uptimeSec: Math.floor((Date.now() - startedAt) / 1000),\n    memory: {\n      rss: mem.rss,\n      heapUsed: mem.heapUsed,\n      heapTotal: mem.heapTotal,\n      external: mem.external,\n    },\n    cache: {\n      size: cache.size,\n      max: cache.max,\n    },\n    activeSubscriptions,\n    mongo: { status: getMongoStatus() },\n    redis: { status: getRedisStatus() },\n  });\n}"}],"edges":[{"source":"health","target":"mongoose","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/middleware/health.js","source_location":"L9","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/middleware/health.js","source_location":"L9"}],"weight":1},{"source":"health","target":"redis","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/middleware/health.js","source_location":"L10","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/middleware/health.js","source_location":"L10"}],"weight":1},{"source":"health","target":"cache","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/middleware/health.js","source_location":"L11","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/da