айден\", {\n      extensions: { code: \"NOT_FOUND\" },\n    });\n  if (!order.riderId || order.riderId.toString() !== rider._id.toString()) {\n    throw new GraphQLError(\"Заказ не назначен вам\", {\n      extensions: { code: \"FORBIDDEN\" },\n    });\n  }\n  assertCanTransition(order, \"AWAITING_CONFIRMATION\");\n\n  order.orderStatus = \"AWAITING_CONFIRMATION\";\n  order.statusTimestamps = order.statusTimestamps || {};\n  order.statusTimestamps.deliveredAt = new Date();\n\n  // Если COD — деньги сразу зафиксированы\n  if (order.paymentMethod === \"COD\") {\n    order.paid = true;\n    if (!order.paidAt) order.paidAt = new Date();\n  }\n\n  await order.save();"}],"edges":[{"source":"delivery","target":"graphql","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/delivery.js","source_location":"L8","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/delivery.js","source_location":"L8"}],"weight":1},{"source":"delivery","target":"order","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/delivery.js","source_location":"L9","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/delivery.js","source_location":"L9"}],"weight":1},{"source":"delivery","target":"rider","relation":"imports_from","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/resolvers/delivery.js","source_location":"L10","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api