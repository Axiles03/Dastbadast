{"__graphifyTsExtractorVersion":63,"nodes":[{"id":"eta","label":"eta.js","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/eta.js","source_location":"L1","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/eta.js","source_location":"L1"}]},{"id":"eta_haversinekm","label":"haversineKm()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/eta.js","source_location":"L16-L26","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/eta.js","source_location":"L16"}],"snippet":"function haversineKm(lat1, lng1, lat2, lng2) {\n  const R = 6371;\n  const dLat = ((lat2 - lat1) * Math.PI) / 180;\n  const dLng = ((lng2 - lng1) * Math.PI) / 180;\n  const a =\n    Math.sin(dLat / 2) ** 2 +\n    Math.cos((lat1 * Math.PI) / 180) *\n      Math.cos((lat2 * Math.PI) / 180) *\n      Math.sin(dLng / 2) ** 2;\n  return 2 * R * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));\n}"},{"id":"eta_etaforridertoaddress","label":"etaForRiderToAddress()","file_type":"code","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/eta.js","source_location":"L37-L56","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/eta.js","source_location":"L37"}],"snippet":"export async function etaForRiderToAddress(fromCoords, toCoords, options = {}) {\n  if (\n    !Array.isArray(fromCoords) ||\n    !Array.isArray(toCoords) ||\n    fromCoords.length < 2 ||\n    toCoords.length < 2\n  ) {\n    return null;\n  }\n  const [lng1, lat1] = fromCoords;\n  const [lng2, lat2] = toCoords;\n  if (lat1 == null || lng1 == null || lat2 == null || lng2 == null) {\n    return null;\n  }\n\n  const { avgSpeedKmh = 25, bufferSec = 180 } = options;\n  const km = haversineKm(lat1, lng1, lat2, lng2);\n  const travelSec = (km / avgSpeedKmh) * 3600;\n  return Math.round(travelSec + bufferSec);\n}"}],"edges":[{"source":"eta","target":"eta_haversinekm","relation":"contains","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/eta.js","source_location":"L16","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/eta.js","source_location":"L16"}],"weight":1},{"source":"eta","target":"eta_etaforridertoaddress","relation":"contains","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/eta.js","source_location":"L37","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/eta.js","source_location":"L37"}],"weight":1},{"source":"eta_etaforridertoaddress","target":"eta_haversinekm","relation":"calls","confidence":"EXTRACTED","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/eta.js","source_location":"L53","layer":"base","provenance":[{"capability_id":"builtin:extract:javascript","stage":"extract","source_file":"/Users/motionup/Desktop/Dastbadast-main/dastbadast-multivendor-api/src/utils/eta.js","source_location":"L53"}],"weight":1}]}