PORT=8001
MONGO_URI=mongodb://localhost:27017/dastbadast
NODE_ENV=development
JWT_SECRET=9d4bd22a9e291916b6dd8f48058120c92156e458389570c2cf042f9824608ddb

# Geoapify (используется для tile-сервера и расчёта маршрутов)
EXPO_PUBLIC_GEOAPIFY_KEY=67d904855a9f4ee599b9b5e93dc4fdba
EXPO_PUBLIC_GEOAPIFY_TILES_KEY=67d904855a9f4ee599b9b5e93dc4fdba

# ⭐ Шаг 2: Redis (для PubSub между инстансами и кэша)
REDIS_URL=redis://127.0.0.1:6379
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=yourpassword

# ⭐ Шаг 2: число воркеров в PM2 cluster
API_INSTANCES=2

# ⭐ Шаг 2: отключить cron (для тестов / dev без Redis)
# DISABLE_CRON=1

# ⭐ Шаг 2: rate limit
RATE_LIMIT_PER_MIN=200

# ⭐ Шаг 2: 0 = in-memory PubSub (single-instance), 1 = Redis (multi-instance)
ENABLE_REDIS_PUBSUB=1
