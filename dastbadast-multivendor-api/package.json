{
  "name": "dastbadast-multivendor-api",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "start:cluster": "node --experimental-vm-modules src/index.js",
    "start:pm2": "pm2 start ecosystem.config.js --env production",
    "stop:pm2": "pm2 delete dastbadast-api",
    "logs:pm2": "pm2 logs dastbadast-api",
    "seed": "node scripts/seed.js",
    "migrate-geo-index": "node scripts/migrate-geo-index.js",
    "migrate-order-status": "node scripts/migrate-order-status.js",
    "migrate-indexes": "node scripts/recommend-indexes.js",
    "cleanup-empty-users": "node scripts/cleanup-empty-users.js",
    "migrate-restaurant-ratings": "node scripts/migrate-restaurant-ratings.js"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@as-integrations/express4": "^1.0.0",
    "@graphql-tools/schema": "^10.0.4",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "expo-server-sdk": "^6.1.0",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "graphql": "^16.9.0",
    "graphql-subscriptions": "^3.0.0",
    "graphql-ws": "^5.16.0",
    "ioredis": "^5.11.1",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.5.1",
    "lucide-react": "^1.17.0",
    "mongoose": "^8.6.0",
    "node-cron": "^3.0.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
