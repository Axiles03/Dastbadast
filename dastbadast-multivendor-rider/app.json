{
  "expo": {
    "name": "dastbadast-multivendor-rider",
    "slug": "dastbadast-multivendor-rider",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dastbadastmultivendorrider",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": ["location", "fetch", "processing"],
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Dastbadast нужен постоянный доступ к геолокации, чтобы клиенты и рестораны видели ваше местоположение в реальном времени при доставке.",
        "NSLocationWhenInUseUsageDescription": "Dastbadast использует геолокацию, чтобы показывать заказы рядом с вами и отслеживать доставку.",
        "NSLocationAlwaysUsageDescription": "Dastbadast отслеживает местоположение в фоне, пока вы доставляете заказ."
      },
      "bundleIdentifier": "tj.dastbadast.rider"
    },
    "android": {
      "package": "tj.dastbadast.rider",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsDownloadToken": "sk.YOUR_SECRET_DOWNLOAD_TOKEN"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Dastbadast нужен доступ к геолокации для отображения ближайших заказов.",
          "locationAlwaysAndWhenInUsePermission": "Dastbadast отслеживает вашу доставку в реальном времени.",
          "locationAlwaysPermission": "Dastbadast продолжает отслеживать доставку, даже когда приложение в фоне.",
          "isAndroidBackgroundLocationEnabled": true,
          "isIosBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "@rnmapbox/maps"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
